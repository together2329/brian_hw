# cocotb sim for the FULL mctp_assembler_v3 DUT (scenario-driven FL-vs-RTL).
#
# Default MODULE runs the generic goal harness FIRST (it resets and writes one
# row per equivalence goal — including the register/protocol/timing/cycle goals
# the datapath test does not drive), then the IP-specific datapath test, which
# replaces the garbage-driven datapath/scenario/state rows with real
# fl_expected-vs-rtl_observed rows by merging into sim/scoreboard_events.jsonl.
# Run order matters: the generic harness must precede the merge.
#
# Usage: make -f Makefile.datapath                       (full flow, default)
#        make -f Makefile.datapath MODULE=test_mctp_datapath   (datapath only)
TOPLEVEL_LANG ?= verilog
SIM ?= icarus

THIS_DIR := $(shell pwd)
RTL_DIR  := $(THIS_DIR)/../../rtl

# Glob all DUT RTL so the build tracks the module decomposition as it evolves
# (e.g. an added _core wrapper) without this TB Makefile going stale. iverilog
# resolves the module hierarchy from TOPLEVEL regardless of file order.
VERILOG_SOURCES := $(wildcard $(RTL_DIR)/*.sv)

TOPLEVEL := mctp_assembler_v3
# Verification-hardening monitor suite (each emits real evidence consumed by the
# emit_*.py emitters that test_runner.py runs after the authoritative sim):
#   test_pl_readback        — write→readback FULL-CONTENT oracle (PAYLOAD_STREAM §7):
#                             real multi-beat payload bytes (up to 4096B) land in
#                             SRAM with no holes and read back byte-exact.
#   test_sram_write_monitor — exact strobed-address set vs the payload window:
#                             no-holes / payload-only / no-header-or-pad-write +
#                             AXI write/read protocol (sim/sram_write_evidence.json).
#   test_apb_desc_readback  — walk the descriptor FIFO head-by-head over APB
#                             (sim/apb_desc_readback_evidence.json).
#   test_safety_properties  — runtime datapath safety-property checker (C1).
# NOTE: `make -f Makefile.datapath` runs the cocotb tests only; the genuine
# verification-hardening JSON artifacts are regenerated by `python3 test_runner.py`
# (which runs the emit_*.py emitters after the sim). Use test_runner.py for signoff.
MODULE ?= test_mctp_assembler_v3,test_mctp_datapath,test_pl_readback,test_sram_write_monitor,test_apb_desc_readback,test_safety_properties

COMPILE_ARGS += -g2012
WAVES ?= 1

export PYTHONPATH := $(THIS_DIR)/../../model:$(THIS_DIR)/../../workflow/tb-gen/runtime:$(THIS_DIR):$(PYTHONPATH)

include $(shell cocotb-config --makefiles)/Makefile.sim
