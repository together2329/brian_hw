          {"name": "bin_in",   "dir": "input",  "width": 4, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "gray_in",  "dir": "input",  "width": 4, "timing": {"kind": "sync", "clock_domain": "main"}},
