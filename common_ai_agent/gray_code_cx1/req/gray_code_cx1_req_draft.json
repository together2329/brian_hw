          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "gray_out matches bin_in XOR (bin_in>>1) for all 16 inputs"}
        ]
      },
      {
        "id": "BC_GC_DECODE",
