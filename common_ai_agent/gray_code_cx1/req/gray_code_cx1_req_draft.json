            "outputs": [{"name": "bin_out", "expr": "gray_to_bin(gray_in)"}],
            "state_updates": []
          }
        ],
        "latency": {"decode_update": "1 clock cycle: bin_out registered one rising clk after valid sampled"},
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/gray_code_cx1.sv"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_gray_code_cx1.py"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "bin_out matches cascaded XOR of gray_in"}
        ]
      },
      {
        "id": "BC_GC_RESET",
        "obligation_refs": ["OBL_GC_RESET_001"],
        "ssot_section": "cycle_model",
        "transactions": [
          {
            "id": "TR_RESET",
            "preconditions": ["rst_n == 0"],
            "outputs": [{"name": "gray_out", "expr": "0"}, {"name": "bin_out", "expr": "0"}],
            "state_updates": [{"name": "sample_count", "expr": "0"}]
          }
        ],
        "reset": "synchronous active-low; outputs clear to 0 on rising clk when rst_n==0",
        "stage_contracts": [
