{
  "hooks": [
    {
      "script": "post_write.sh",
      "trigger": "after_tool",
      "conditions": {
        "tool_names": ["write_file", "replace_in_file"],
        "file_extensions": [".v", ".sv"]
      }
    },
    {
      "script": "benchmark_tick.sh",
      "trigger": "before_llm",
      "conditions": {
        "every_n_iterations": 1
      }
    },
    {
      "script": "error_capture.sh",
      "trigger": "after_tool",
      "conditions": {
        "tool_names": ["run_command"],
        "output_contains": ["Error", "error:", "FAILED", "failed"],
        "min_iteration": 2
      }
    }
  ]
}
