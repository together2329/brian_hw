{
  "name": "rtl-gen",
  "description": "RTL generation agent — spawned by mas-gen for module implementation",
  "env": {
    "MAX_ITERATIONS": "150",
    "ENABLE_MARKDOWN_RENDER": "true",
    "WORKFLOW_DISABLED_TOOLS": "ask_user,record_ssot_qa"
  },
  "skills": {
    "force_activate": ["verilog-expert"],
    "disable": []
  },
  "system_prompt_mode": "prepend",
  "plan_prompt_mode": "prepend",
  "compression_prompt_mode": "replace"
}
