{
  "name": "sim",
  "description": "Simulation workspace \u2014 compile, run, debug, coverage, generate sim_report.txt",
  "env": {
    "MAX_ITERATIONS": "150",
    "ENABLE_MARKDOWN_RENDER": "true",
    "WORKFLOW_DISABLED_TOOLS": "ask_user,record_ssot_qa,dispatch_workflow"
  },
