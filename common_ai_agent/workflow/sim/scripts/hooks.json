{
  "hooks": [
    {
      "script": "sim_capture.sh",
      "trigger": "after_tool",
      "conditions": {
        "tool_names": ["run_command"],
        "output_contains": ["errors", "warnings", "PASS", "FAIL", "[PASS]", "[FAIL]"]
      }
    },
    {
      "script": "post_write.sh",
      "trigger": "after_tool",
      "conditions": {
        "tool_names": ["write_file", "replace_in_file"],
        "file_extensions": [".sv", ".v"]
      }
    }
  ]
}
