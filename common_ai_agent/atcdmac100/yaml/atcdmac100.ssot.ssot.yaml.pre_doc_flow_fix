rtl_contract:
  owner: ssot-gen
  type: ssot_derived_rule_contract
  transaction: start_transfer
  clock: hclk
  reset: hresetn
  reset_active: low
  sample_condition: ctrl.start && !busy && len_bytes != 0
  input_map:
    paddr: paddr
    pwdata: pwdata
    hrdata: hrdata
    hready: hready
    hresp: hresp
    dma_req: dma_req
    psel: psel
    penable: penable
    pwrite: pwrite
    hgrant: hgrant
  output_map:
    pready: pready
    prdata: prdata
    pslverr: pslverr
    haddr: haddr
    hwrite: hwrite
    htrans: htrans
    hsize: hsize
    hburst: hburst
    hwdata: hwdata
    dma_ack: dma_ack
    irq: irq
  ready_output: pready
  output_valid: irq
  contract_invariants:
  - RTL-visible behavior implements referenced function_model transactions.
  - APB/AHB observation follows cycle_model handshake and latency rules.
  output_rules:
  - name: irq_contract
    port: irq
    expr: '|(int_status & int_en) & ctrl.int_en_global'
    width: 1
    description: Combined interrupt expression.
  - name: request_ack
    port: dma_ack
    expr: dma_req & {NUM_CHANNELS{ctrl.hw_req_en}}
    width: NUM_CHANNELS
    description: FunctionalModel output observable mapped to DUT output port.
  - name: pready_reset
    port: pready
    expr: '0'
    width: 1
    description: FunctionalModel output observable mapped to DUT output port.
  - name: htrans_reset
    port: htrans
    expr: '0'
    width: 2
    description: FunctionalModel output observable mapped to DUT output port.
  - name: apb_write_error
    port: pslverr
    expr: addr_decode_error
    width: 1
    description: FunctionalModel output observable mapped to DUT output port.
  - name: apb_read_data
    port: prdata
    expr: reg_read_mux(paddr)
    width: DATA_WIDTH
    description: FunctionalModel output observable mapped to DUT output port.
  - name: read_addr
    port: haddr
    expr: src_addr + read_bytes_issued
    width: ADDR_WIDTH
    description: FunctionalModel output observable mapped to DUT output port.
  - name: read_dir
    port: hwrite
    expr: '0'
    width: 1
    description: FunctionalModel output observable mapped to DUT output port.
  - name: read_size
    port: hsize
    expr: $clog2(DATA_WIDTH/8)
    width: 3
    description: FunctionalModel output observable mapped to DUT output port.
  - name: read_burst
    port: hburst
    expr: '1'
    width: 3
    description: FunctionalModel output observable mapped to DUT output port.
  - name: write_data
    port: hwdata
    expr: fifo_rdata
    width: DATA_WIDTH
    description: FunctionalModel output observable mapped to DUT output port.
  unresolved_expression_refs:
  - ADDR_WIDTH
  - DATA_WIDTH
  - LEN_WIDTH
  - addr_decode_error
  - addr_is_CTRL
  - addr_is_DST_ADDR
  - addr_is_INT_EN
  - addr_is_INT_STATUS
  - addr_is_LEN
  - addr_is_SRC_ADDR
  - fifo_rdata
  - read_first_beat
  - write_first_beat
