security:
  classification: non_secure_leaf_ip
  assets:
  - name: configuration_state
    protection: CSR updates must be deterministic, reset-safe, and blocked from illegal side effects.
  - name: copied_data_integrity
    protection: Destination write data must match source read data in order.
