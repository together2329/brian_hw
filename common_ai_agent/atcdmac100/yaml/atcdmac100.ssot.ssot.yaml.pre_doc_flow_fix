top_module:
  name: atcdmac100
  file: rtl/atcdmac100.sv
  version: DS079_V1.2_engineering_draft
  type: rtl
  description: ATCDMAC100-compatible programmable DMA controller with APB control registers, AHB-Lite master memory copy datapath, DMA request acknowledge, and maskable interrupt output.
  target:
    technology: generic
    clock_freq_mhz: 100
    area_um2: null
    power_mw: null
  reference_spec: AndeShape ATCDMAC100 DS079 V1.2
sub_modules:
- name: atcdmac100_apb_regs
  type: register_block
  description: APB register decode, writable configuration registers, status reflection, and W1C interrupt clear.
  implements:
  - cfg_regs
  - interrupt
  register_refs:
  - CTRL
  - SRC_ADDR
  - DST_ADDR
  - LEN
  - STATUS
  - INT_EN
  - INT_STATUS
  - registers.register_list
  function_model_refs:
  - apb_write_reg
  - apb_read_reg
  - clear_interrupt
  - function_model.transactions.apb_write_reg
  - function_model.transactions.apb_read_reg
  - function_model.transactions.clear_interrupt
  - function_model.state_variables
  dataflow_refs:
  - apb_control_path
  - dataflow
  source_sections:
  - dataflow
  - test_requirements
  - registers
  test_refs:
  - test_requirements
- name: atcdmac100_channel
  type: control_fsm
  description: Single-channel DMA control FSM, counters, request qualification, completion, and error state.
  implements:
  - mem_to_mem_dma
  - error_handling
  fsm_refs:
  - channel_fsm
  - fsm
  dataflow_refs:
  - dma_copy_path
  function_model_refs:
  - start_transfer
  - complete_transfer
  - ahb_error
  - function_model.transactions.reset
  - function_model.transactions.start_transfer
  - function_model.transactions.complete_transfer
  - function_model.transactions.ahb_error
  cycle_model_refs:
  - cm_dma_copy
  - cycle_model
  source_sections:
  - cycle_model
  - features
  - fsm
  - decomposition
  feature_refs:
  - features
  decomposition_refs:
  - decomposition
- name: atcdmac100_ahb_master
  type: bus_master
  description: AHB-Lite address/control generation, read capture FIFO, and write data phase generation.
  implements:
  - mem_to_mem_dma
  dataflow_refs:
  - ahb_read_path
  - ahb_write_path
  function_model_refs:
  - issue_read_beat
  - issue_write_beat
  - function_model.transactions.issue_read_beat
  - function_model.transactions.issue_write_beat
  cycle_model_refs:
  - cm_ahb_handshake
- name: atcdmac100_irq
  type: interrupt_controller
  description: Done/error interrupt status, mask, global enable, and irq aggregation.
  implements:
  - interrupt
  register_refs:
  - STATUS
  - INT_EN
  - INT_STATUS
  function_model_refs:
  - complete_transfer
  - ahb_error
  - clear_interrupt
- name: atcdmac100
  file: rtl/atcdmac100.sv
  ownership: manifest
  ssot_gen: true
  description: Top-level integration module matching SSOT top_module
decomposition:
  strategy: ssot_owned_leaf_decomposition
  owners:
  - module: atcdmac100_apb_regs
    file: rtl/atcdmac100_apb_regs.sv
    responsibility: Register decode and APB-visible CSR behavior.
    source_sections:
    - registers
    - function_model.transactions.apb_write_reg
    - function_model.transactions.apb_read_reg
  - module: atcdmac100_channel
    file: rtl/atcdmac100_channel.sv
    responsibility: DMA channel FSM, counters, and terminal status.
    source_sections:
    - fsm.channel_fsm
    - function_model.transactions.start_transfer
    - function_model.transactions.complete_transfer
    - function_model.transactions.ahb_error
  - module: atcdmac100_ahb_master
    file: rtl/atcdmac100_ahb_master.sv
    responsibility: AHB-Lite read/write beat issue and buffering.
    source_sections:
    - dataflow.ahb_read_path
    - dataflow.ahb_write_path
    - cycle_model.handshake_rules
  - module: atcdmac100_irq
    file: rtl/atcdmac100_irq.sv
    responsibility: Interrupt status, masking, W1C clear, and irq output.
    source_sections:
    - interrupts
    - function_model.transactions.clear_interrupt
  integration_policy: Top-level rtl/atcdmac100.sv wires the owned slices; any changed port or split requires SSOT update before RTL.
  source_refs:
  - sub_modules
  - function_model
  - cycle_model
  - integration
parameters:
- name: ADDR_WIDTH
  type: int
  default: 32
  description: System byte address width.
- name: DATA_WIDTH
  type: int
  default: 32
  description: AHB/APB data width for the draft baseline.
- name: LEN_WIDTH
  type: int
  default: 16
  description: DMA byte length counter width.
- name: NUM_CHANNELS
  type: int
  default: 1
  description: Engineering draft implements one DMA channel.
- name: FIFO_DEPTH
  type: int
  default: 4
  description: Internal read-data FIFO depth in DATA_WIDTH words.
io_list:
  clock_domains:
  - name: hclk
    frequency_mhz: 100
    description: Primary DMA, APB, and AHB clock domain.
    ports:
    - name: hclk
      width: 1
      direction: input
      description: Controller clock.
  resets:
  - name: hresetn
    polarity: active_low
    sync_async: synchronous
    description: Active-low reset sampled on hclk in this engineering draft.
    ports:
    - name: hresetn
      width: 1
      direction: input
      description: Active-low controller reset.
  interfaces:
  - name: apb_slave
    type: apb
    role: slave
    clock_domain: hclk
    reset_domain: hresetn
    description: APB-style CSR programming interface.
    protocol:
      acceptance: A transfer completes when psel && penable && pready.
      setup: paddr, pwrite, pwdata are sampled from the setup/access phase.
      backpressure: pready may deassert; the draft register file returns pready high outside reset.
    ports:
    - name: psel
      direction: input
      width: 1
      description: APB select.
    - name: penable
      direction: input
      width: 1
      description: APB access phase.
    - name: pwrite
      direction: input
      width: 1
      description: APB write direction.
    - name: paddr
      direction: input
      width: ADDR_WIDTH
      description: APB byte address.
    - name: pwdata
      direction: input
      width: DATA_WIDTH
      description: APB write data.
    - name: prdata
      direction: output
      width: DATA_WIDTH
      description: APB read data.
    - name: pready
      direction: output
      width: 1
      description: APB ready.
    - name: pslverr
      direction: output
      width: 1
      description: APB decode/protection error.
  - name: ahb_lite_master
    type: ahb_lite
    role: master
    clock_domain: hclk
    reset_domain: hresetn
    description: AHB-Lite master used for source reads and destination writes.
    protocol:
      acceptance: Address/control is valid when htrans[1] && hgrant; a beat completes when hready is high.
      response: hresp high on a completed beat terminates the channel with error status.
      stability: haddr, hwrite, htrans, hsize, hburst, and hwdata remain stable while hready is low.
    ports:
    - name: hgrant
      direction: input
      width: 1
      description: External grant/accept qualifier.
    - name: hready
      direction: input
      width: 1
      description: AHB ready/backpressure.
    - name: hresp
      direction: input
      width: 1
      description: AHB error response.
    - name: hrdata
      direction: input
      width: DATA_WIDTH
      description: AHB read data.
    - name: haddr
      direction: output
      width: ADDR_WIDTH
      description: AHB byte address.
    - name: hwrite
      direction: output
      width: 1
      description: AHB write direction.
    - name: htrans
      direction: output
      width: 2
      description: AHB transfer type.
    - name: hsize
      direction: output
      width: 3
      description: AHB transfer size.
    - name: hburst
      direction: output
      width: 3
      description: AHB burst type.
    - name: hwdata
      direction: output
      width: DATA_WIDTH
      description: AHB write data.
  - name: dma_request_irq
    type: native_dma_request_interrupt
    role: mixed
    clock_domain: hclk
    reset_domain: hresetn
    description: Optional hardware request input, acknowledge, and combined interrupt output.
    protocol:
      request: dma_req qualifies channel start when CTRL.hw_req_en is set; software start ignores dma_req.
      acknowledge: dma_ack asserts for the accepted request/channel while service is active.
      interrupt: irq is level high while an enabled INT_STATUS bit is set and clears after W1C.
    ports:
    - name: dma_req
      direction: input
      width: NUM_CHANNELS
      description: Hardware DMA request.
    - name: dma_ack
      direction: output
      width: NUM_CHANNELS
      description: Hardware DMA request acknowledge.
    - name: irq
      direction: output
      width: 1
      description: Combined DMA interrupt.
features:
- id: cfg_regs
  description: APB programmable source, destination, length, control, status, interrupt enable, and W1C interrupt status registers.
- id: mem_to_mem_dma
  description: Copy len_bytes from SRC_ADDR to DST_ADDR using ordered AHB-Lite read and write beats.
- id: interrupt
  description: Maskable terminal-count and error interrupt status with W1C clear.
- id: error_handling
  description: AHB response error stops the channel, records ERR, and blocks further transfer until software recovery/reset.
dataflow:
  paths:
  - id: apb_control_path
    sources:
    - psel
    - penable
    - pwrite
    - paddr
    - pwdata
    sinks:
    - CTRL
    - SRC_ADDR
    - DST_ADDR
    - LEN
    - INT_EN
    - INT_STATUS
    - prdata
    - pready
    - pslverr
    ordering: CSR writes update state on accepted APB write cycles; reads reflect the latest committed state.
  - id: dma_copy_path
    sources:
    - SRC_ADDR
    - hrdata
    sinks:
    - DST_ADDR
    - hwdata
    ordering: Each destination write uses the previously captured source read data for the same byte offset.
  - id: ahb_read_path
    sources:
    - src_addr
    - read_bytes_issued
    - hready
    - hresp
    - hrdata
    sinks:
    - haddr
    - hwrite
    - htrans
    - hsize
    - hburst
    - fifo_wdata
    ordering: Read address beats issue in monotonically increasing byte-offset order when FIFO space is available.
  - id: ahb_write_path
    sources:
    - dst_addr
    - bytes_done
    - fifo_rdata
    - hready
    - hresp
    sinks:
    - haddr
    - hwrite
    - htrans
    - hsize
    - hburst
    - hwdata
    ordering: Write beats drain FIFO data in read order and advance bytes_done only on completed non-error writes.
  invariants:
  - No write beat may be issued before its corresponding read data is captured.
  - Address increments are DATA_WIDTH/8 bytes in the draft baseline unless DS079 reconciliation changes alignment policy.
function_model:
  purpose: Cycle-independent behavioral contract for atcdmac100.
  state_variables:
  - name: ctrl
    width: DATA_WIDTH
    reset: 0
    description: Control register architectural state.
  - name: src_addr
    width: ADDR_WIDTH
    reset: 0
    description: Current source base address.
  - name: dst_addr
    width: ADDR_WIDTH
    reset: 0
    description: Current destination base address.
  - name: len_bytes
    width: LEN_WIDTH
    reset: 0
    description: Programmed transfer length in bytes.
  - name: bytes_done
    width: LEN_WIDTH
    reset: 0
    description: Bytes completed by destination writes.
  - name: read_bytes_issued
    width: LEN_WIDTH
    reset: 0
    description: Bytes issued as source reads.
  - name: busy
    width: 1
    reset: 0
    description: Channel active flag.
  - name: done
    width: 1
    reset: 0
    description: Terminal-count status.
  - name: err
    width: 1
    reset: 0
    description: Error status.
  - name: int_en
    width: 2
    reset: 0
    description: Done/error interrupt enable bits.
  - name: int_status
    width: 2
    reset: 0
    description: Done/error interrupt pending bits.
  transactions:
  - id: reset
    name: reset_contract
    preconditions:
    - hresetn == 0
    inputs:
    - hresetn
    outputs:
    - bus outputs idle, irq low, APB not ready during reset
    - name: pready_reset
      port: pready
      expr: '0'
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: htrans_reset
      port: htrans
      expr: '0'
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: irq_reset
      port: irq
      expr: '0'
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - state: ctrl
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: src_addr
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: dst_addr
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: len_bytes
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: bytes_done
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: read_bytes_issued
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: busy
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: done
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: err
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: int_en
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: int_status
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    side_effects:
    - All architectural state variables return to reset values.
    state_updates:
    - name: ctrl
      expr: '0'
      width: DATA_WIDTH
    - name: src_addr
      expr: '0'
      width: ADDR_WIDTH
    - name: dst_addr
      expr: '0'
      width: ADDR_WIDTH
    - name: len_bytes
      expr: '0'
      width: LEN_WIDTH
    - name: bytes_done
      expr: '0'
      width: LEN_WIDTH
    - name: read_bytes_issued
      expr: '0'
      width: LEN_WIDTH
    - name: busy
      expr: '0'
      width: 1
    - name: done
      expr: '0'
      width: 1
    - name: err
      expr: '0'
      width: 1
    - name: int_en
      expr: '0'
      width: 2
    - name: int_status
      expr: '0'
      width: 2
    output_rules:
    - name: pready_reset
      port: pready
      expr: '0'
      width: 1
    - name: htrans_reset
      port: htrans
      expr: '0'
      width: 2
    - name: irq_reset
      port: irq
      expr: '0'
      width: 1
  - id: apb_write_reg
    name: apb_write_register
    preconditions:
    - psel && penable && pwrite && pready
    inputs:
    - paddr
    - pwdata
    outputs:
    - pready completes the access and pslverr reports decode error
    - name: apb_write_ready
      port: pready
      expr: '1'
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: apb_write_error
      port: pslverr
      expr: addr_decode_error
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - state: src_addr
      expr: (pwdata[ADDR_WIDTH-1:0] if addr_is_SRC_ADDR else src_addr)
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: dst_addr
      expr: (pwdata[ADDR_WIDTH-1:0] if addr_is_DST_ADDR else dst_addr)
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: len_bytes
      expr: (pwdata[LEN_WIDTH-1:0] if addr_is_LEN else len_bytes)
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: ctrl
      expr: (pwdata if addr_is_CTRL else ctrl)
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: int_en
      expr: (pwdata[1:0] if addr_is_INT_EN else int_en)
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: int_status
      expr: ((int_status & ~pwdata[1:0]) if addr_is_INT_STATUS else int_status)
      description: Mirrored from executable state_updates for SSOT validator completeness.
    side_effects:
    - Selected RW register field updates; INT_STATUS performs W1C clear.
    state_updates:
    - name: src_addr
      expr: (pwdata[ADDR_WIDTH-1:0] if addr_is_SRC_ADDR else src_addr)
      width: ADDR_WIDTH
    - name: dst_addr
      expr: (pwdata[ADDR_WIDTH-1:0] if addr_is_DST_ADDR else dst_addr)
      width: ADDR_WIDTH
    - name: len_bytes
      expr: (pwdata[LEN_WIDTH-1:0] if addr_is_LEN else len_bytes)
      width: LEN_WIDTH
    - name: ctrl
      expr: (pwdata if addr_is_CTRL else ctrl)
      width: DATA_WIDTH
    - name: int_en
      expr: (pwdata[1:0] if addr_is_INT_EN else int_en)
      width: 2
    - name: int_status
      expr: ((int_status & ~pwdata[1:0]) if addr_is_INT_STATUS else int_status)
      width: 2
    output_rules:
    - name: apb_write_ready
      port: pready
      expr: '1'
      width: 1
    - name: apb_write_error
      port: pslverr
      expr: addr_decode_error
      width: 1
  - id: apb_read_reg
    name: apb_read_register
    preconditions:
    - psel && penable && !pwrite && pready
    inputs:
    - paddr
    outputs:
    - prdata returns selected register value; pslverr reports decode error
    - name: apb_read_data
      port: prdata
      expr: reg_read_mux(paddr)
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: apb_read_ready
      port: pready
      expr: '1'
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: apb_read_error
      port: pslverr
      expr: addr_decode_error
      description: Mirrored from executable output_rules for SSOT validator completeness.
    side_effects:
    - No architectural state changes on legal reads.
    output_rules:
    - name: apb_read_data
      port: prdata
      expr: reg_read_mux(paddr)
      width: DATA_WIDTH
    - name: apb_read_ready
      port: pready
      expr: '1'
      width: 1
    - name: apb_read_error
      port: pslverr
      expr: addr_decode_error
      width: 1
  - id: start_transfer
    name: start_dma_transfer
    preconditions:
    - 'ctrl.start && !busy && len_bytes != 0 && (ctrl.hw_req_en ? |dma_req : 1''b1)'
    inputs:
    - ctrl
    - len_bytes
    - dma_req
    outputs:
    - dma_ack acknowledges accepted hardware request when enabled
    - name: request_ack
      port: dma_ack
      expr: dma_req & {NUM_CHANNELS{ctrl.hw_req_en}}
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - state: busy
      expr: '1'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: done
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: err
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: bytes_done
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    - state: read_bytes_issued
      expr: '0'
      description: Mirrored from executable state_updates for SSOT validator completeness.
    side_effects:
    - Channel enters busy state, clears stale done/error status, and resets counters.
    state_updates:
    - name: busy
      expr: '1'
      width: 1
    - name: done
      expr: '0'
      width: 1
    - name: err
      expr: '0'
      width: 1
    - name: bytes_done
      expr: '0'
      width: LEN_WIDTH
    - name: read_bytes_issued
      expr: '0'
      width: LEN_WIDTH
    output_rules:
    - name: request_ack
      port: dma_ack
      expr: dma_req & {NUM_CHANNELS{ctrl.hw_req_en}}
      width: NUM_CHANNELS
  - id: issue_read_beat
    name: issue_ahb_read_beat
    preconditions:
    - busy && fifo_not_full && read_bytes_issued < len_bytes && hgrant && hready
    inputs:
    - src_addr
    - read_bytes_issued
    - hgrant
    - hready
    outputs:
    - AHB address/control emits a read beat
    - name: read_addr
      port: haddr
      expr: src_addr + read_bytes_issued
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: read_dir
      port: hwrite
      expr: '0'
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: read_trans
      port: htrans
      expr: (2 if read_first_beat else 3)
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: read_size
      port: hsize
      expr: $clog2(DATA_WIDTH/8)
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: read_burst
      port: hburst
      expr: '1'
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - state: read_bytes_issued
      expr: read_bytes_issued + (DATA_WIDTH/8)
      description: Mirrored from executable state_updates for SSOT validator completeness.
    side_effects:
    - Read issue counter advances by DATA_WIDTH/8 bytes after an accepted non-error read address phase.
    state_updates:
    - name: read_bytes_issued
      expr: read_bytes_issued + (DATA_WIDTH/8)
      width: LEN_WIDTH
    output_rules:
    - name: read_addr
      port: haddr
      expr: src_addr + read_bytes_issued
      width: ADDR_WIDTH
    - name: read_dir
      port: hwrite
      expr: '0'
      width: 1
    - name: read_trans
      port: htrans
      expr: (2 if read_first_beat else 3)
      width: 2
    - name: read_size
      port: hsize
      expr: $clog2(DATA_WIDTH/8)
      width: 3
    - name: read_burst
      port: hburst
      expr: '1'
      width: 3
  - id: issue_write_beat
    name: issue_ahb_write_beat
    preconditions:
    - busy && fifo_not_empty && hgrant && hready
    inputs:
    - dst_addr
    - bytes_done
    - fifo_rdata
    - hgrant
    - hready
    outputs:
    - AHB address/control/data emits a write beat
    - name: write_addr
      port: haddr
      expr: dst_addr + bytes_done
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: write_dir
      port: hwrite
      expr: '1'
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: write_trans
      port: htrans
      expr: (2 if write_first_beat else 3)
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: write_size
      port: hsize
      expr: $clog2(DATA_WIDTH/8)
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: write_burst
      port: hburst
      expr: '1'
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - name: write_data
      port: hwdata
      expr: fifo_rdata
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - state: bytes_done
      expr: bytes_done + (DATA_WIDTH/8)
      description: Mirrored from executable state_updates for SSOT validator completeness.
    side_effects:
    - Completed non-error write advances bytes_done by DATA_WIDTH/8 bytes.
    state_updates:
    - name: bytes_done
      expr: bytes_done + (DATA_WIDTH/8)
      width: LEN_WIDTH
    output_rules:
    - name: write_addr
      port: haddr
      expr: dst_addr + bytes_done
      width: ADDR_WIDTH
    - name: write_dir
      port: hwrite
      expr: '1'
      width: 1
    - name: write_trans
      port: htrans
      expr: (2 if write_first_beat else 3)
      width: 2
    - name: write_size
      port: hsize
      expr: $clog2(DATA_WIDTH/8)
      width: 3
    - name: write_burst
      port: hburst
      expr: '1'
      width: 3
