cycle_model:
  purpose: Cycle and handshake contract for rtl-gen and waveform verification.
  executable: pymtl3
  clock: hclk
  reset:
    signal: hresetn
    polarity: active_low
    assertion: Reset returns state variables to function_model reset values.
    deassertion: Transactions may be accepted on the first hclk edge after reset release.
  latency:
    apb_access:
      min_cycles: 1
      max_cycles: 2
      description: APB setup plus access; draft register file is zero-wait outside reset.
    ahb_beat:
      min_cycles: 1
      max_cycles: null
      description: One accepted beat per hready cycle; stalls extend latency.
    dma_copy:
      min_cycles: 2
      max_cycles: null
      description: At least one read and one write beat per DATA_WIDTH bytes plus stalls.
  handshake_rules:
  - signal: apb_slave
    rule: paddr, pwrite, and pwdata remain stable from setup through accepted access psel && penable && pready.
  - signal: ahb_lite_master
    rule: haddr/hwrite/htrans/hsize/hburst/hwdata remain stable while hready is low.
  - signal: dma_request_irq
    rule: irq remains asserted while any enabled INT_STATUS bit is set; dma_ack follows accepted request service.
  pipeline:
  - stage: S0_APB_PROGRAM
    cycle: 0..N
    action: Software programs source, destination, length, interrupt enable, and control.
  - stage: S1_ARBITRATE
    cycle: N..M
    action: Channel qualifies start and waits for hgrant/hready.
  - stage: S2_READ
    cycle: M..K
    action: Issue ordered AHB read beats when FIFO has space.
  - stage: S3_WRITE
    cycle: K..L
    action: Issue ordered AHB write beats using captured FIFO data.
  - stage: S4_COMPLETE
    cycle: L
    action: Set done or err status and update irq.
  ordering:
  - CSR writes commit before a subsequent start condition observes them.
  - Read data for offset X is captured before destination write for offset X.
  - bytes_done advances only after a completed non-error write beat.
  - Backpressure stalls only the active APB or AHB phase and must not corrupt counters or FIFO order.
  backpressure:
  - APB may wait by deasserting pready.
  - AHB may wait by deasserting hready; all master outputs remain stable during wait.
  performance:
    frequency_mhz: 100
    throughput:
      sustained_beats_per_cycle: 1
      condition: No hready stalls, FIFO not empty/full as applicable.
    outstanding:
      max: 1
      description: Single in-order channel with bounded FIFO; no out-of-order completions.
    depth:
      pipeline_stages: 5
      queue_depth: FIFO_DEPTH
      description: Program/arbitrate/read/write/complete stages with read FIFO buffering.
  observability:
  - Every function_model transaction maps to a pipeline stage and test scenario.
  backend_policy: Use PyMTL3 for the clocked cycle model shell; FunctionalModel remains the behavioral oracle.
clock_reset_domains:
  domains:
  - clock: hclk
    reset: hresetn
    frequency_mhz: 100
    reset_scheme: synchronous_active_low
  reset_behavior:
  - CSR, channel FSM, counters, FIFO state, APB outputs, AHB outputs, dma_ack, and irq reset to idle values.
cdc_requirements:
  required: false
  rationale: Engineering draft uses one hclk/hresetn domain.
  checks:
  - No CDC paths expected unless DS079 reconciliation adds another clock.
rdc_requirements:
  required: false
  rationale: Single reset domain in this draft.
  checks:
  - No reset-domain crossings expected unless DS079 reconciliation adds another reset.
registers:
  register_list:
  - name: CTRL
    offset: 0
    width: 32
    access: rw
    reset: 0
    description: Control register.
    fields:
    - name: start
      bits: 0:0
      access: rw1s
      reset: 0
      description: Write 1 to request channel start.
      write_effect: Sets start request when channel is idle.
    - name: int_en_global
      bits: '1:1'
      access: rw
      reset: 0
      description: Global IRQ enable.
      write_effect: Stores written value.
    - name: hw_req_en
      bits: '2:2'
      access: rw
      reset: 0
      description: Enable dma_req qualification.
      write_effect: Stores written value.
    - name: src_inc
      bits: '3:3'
      access: rw
      reset: 1
      description: Increment source address per beat.
      write_effect: Stores written value.
    - name: dst_inc
      bits: '4:4'
      access: rw
      reset: 1
      description: Increment destination address per beat.
      write_effect: Stores written value.
  - name: SRC_ADDR
    offset: 4
    width: 32
    access: rw
    reset: 0
    description: Source byte address.
    fields:
    - name: src_addr
      bits: '31:0'
      access: rw
      reset: 0
      description: Source base address.
      write_effect: Stores written address when channel is idle.
  - name: DST_ADDR
    offset: 8
    width: 32
    access: rw
    reset: 0
    description: Destination byte address.
    fields:
    - name: dst_addr
      bits: '31:0'
      access: rw
      reset: 0
      description: Destination base address.
      write_effect: Stores written address when channel is idle.
  - name: LEN
    offset: 12
    width: 32
    access: rw
    reset: 0
    description: Transfer length in bytes.
    fields:
    - name: len_bytes
      bits: '15:0'
      access: rw
      reset: 0
      description: Number of bytes to copy.
      write_effect: Stores requested length when channel is idle.
  - name: STATUS
    offset: 16
    width: 32
    access: ro
    reset: 0
    description: Channel status.
    fields:
    - name: busy
      bits: 0:0
      access: ro
      reset: 0
      description: Transfer is active.
    - name: done
      bits: '1:1'
      access: ro
      reset: 0
      description: Transfer completed normally.
    - name: err
      bits: '2:2'
      access: ro
      reset: 0
      description: Transfer stopped on error.
  - name: INT_EN
    offset: 20
    width: 32
    access: rw
    reset: 0
    description: Interrupt enable bits.
    fields:
    - name: done_en
      bits: 0:0
      access: rw
      reset: 0
      description: Enable done interrupt.
      write_effect: Stores written enable.
    - name: err_en
      bits: '1:1'
      access: rw
      reset: 0
      description: Enable error interrupt.
      write_effect: Stores written enable.
  - name: INT_STATUS
    offset: 24
    width: 32
    access: w1c_ro
    reset: 0
    description: Interrupt pending status; write one to clear.
    fields:
    - name: done_irq
      bits: 0:0
      access: w1c
      reset: 0
      description: Done interrupt pending.
      write_effect: Writing 1 clears the pending bit.
    - name: err_irq
      bits: '1:1'
      access: w1c
      reset: 0
      description: Error interrupt pending.
      write_effect: Writing 1 clears the pending bit.
memory:
  instances: []
  addressing:
    policy: No internal memory array is architecturally required; external AHB memory supplies source/destination storage.
  storage_policy: Only FIFO buffering is implementation detail bounded by FIFO_DEPTH; no firmware-visible memory.
interrupts:
  present: true
  sources:
  - name: irq_done
    source: INT_STATUS.done_irq
    enable: INT_EN.done_en & CTRL.int_en_global
    output: irq
    clear: write 1 to INT_STATUS[0]
  - name: irq_error
    source: INT_STATUS.err_irq
    enable: INT_EN.err_en & CTRL.int_en_global
    output: irq
    clear: write 1 to INT_STATUS[1]
  aggregation: irq = |(INT_STATUS[1:0] & INT_EN[1:0]) & CTRL.int_en_global
fsm:
  control:
    id: channel_fsm
    states:
    - IDLE
    - ARBITRATE
    - READ
    - WRITE
    - DONE
    - ERROR
    reset_state: IDLE
    transitions:
    - from: IDLE
      to: ARBITRATE
      when: start_transfer
    - from: ARBITRATE
      to: READ
      when: hgrant && hready && fifo_not_full
    - from: READ
      to: WRITE
      when: read_data_valid || fifo_not_empty
    - from: WRITE
      to: READ
      when: more_bytes && fifo_has_space && !hresp
    - from: WRITE
      to: DONE
      when: last_write_complete && !hresp
    - from: ARBITRATE
      to: ERROR
      when: hready && hresp
    - from: READ
      to: ERROR
      when: hready && hresp
    - from: WRITE
      to: ERROR
      when: hready && hresp
    - from: DONE
      to: IDLE
      when: software clears start or programs next transfer
    - from: ERROR
      to: IDLE
      when: software clear/restart or reset
