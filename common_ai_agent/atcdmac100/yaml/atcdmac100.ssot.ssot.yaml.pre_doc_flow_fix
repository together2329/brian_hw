error_handling:
  error_sources:
  - id: ERR_APB_DECODE
    condition: APB access to an undefined offset
    architectural_effect: pslverr=1 and no state corruption.
  - id: ERR_AHB_RESP
    condition: hready && hresp during active DMA
    architectural_effect: busy=0, err=1, INT_STATUS[1]=1, htrans=IDLE.
  propagation:
  - APB decode errors are returned on pslverr.
  - AHB errors update STATUS/INT_STATUS and may assert irq when enabled.
  recovery:
  - action: reset
    clears:
    - ctrl
    - status
    - int_status
    - counters
    preserves: []
  - action: software_clear_and_restart
    clears:
    - err
    - int_status
