    output_rules:
    - name: error_irq
      port: irq
      expr: '|((int_status | 2) & int_en)'
      width: 1
    - name: error_idle
      port: htrans
      expr: '0'
      width: 2
  - id: clear_interrupt
    name: clear_interrupt_status
    preconditions:
    - psel && penable && pwrite && addr_is_INT_STATUS
    inputs:
    - pwdata
    - int_status
    - int_en
    outputs:
    - irq reflects remaining enabled interrupt status after W1C
    - name: irq_after_clear
      port: irq
      expr: '|((int_status & ~pwdata[1:0]) & int_en)'
      description: Mirrored from executable output_rules for SSOT validator completeness.
    - state: int_status
      expr: int_status & ~pwdata[1:0]
      description: Mirrored from executable state_updates for SSOT validator completeness.
    side_effects:
    - INT_STATUS bits written as 1 are cleared; other bits remain unchanged.
