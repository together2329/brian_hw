    - state: int_status
      expr: int_status | 2
      description: Mirrored from executable state_updates for SSOT validator completeness.
    side_effects:
    - Channel clears busy, sets error, and latches error interrupt status.
    error_cases:
    - condition: AHB read or write beat completes with hresp high.
