{
  "schema_version": 1,
  "type": "human_llm_authority_manifest",
  "ip": "atciic100_target",
  "principle": "Human = 정답/목표/판단 기준 확정. LLM = 그 기준에 수렴하도록 생성·실행·수정 loop 수행.",
  "cardinal_rule": "LLM은 RTL/test/vector/report을 자유롭게 수정한다. 그러나 RTL이 FL과 어긋났을 때 FL을 바꿔서 PASS시키는 것은 금지된다. FL/spec/coverage_goal/perf_target/interface contract 변경은 사람 승인 없이는 불가능하며, PASS의 의미는 항상 locked truth(FL+SSOT) 기준으로만 판단한다. model_signature.json drift가 감지되면 downstream worker는 [SSOT HANDOFF] golden_changed를 발행하고 멈춰야 한다.",
  "general_flow_guarantee": "이 manifest는 IP-agnostic이다. 9 gates / 9 loops / 6 rules / repo_layout 모두 특정 IP의 프로토콜이나 도메인을 가정하지 않으며, 게이트 상태는 on-disk artifact 존재/내용만 근거로 자동 감지된다. 어떤 IP의 SSOT도 동일한 manifest 골격을 받는다.",
  "operating_rules": [
    {
      "id": "R1",
      "rule": "LLM은 RTL을 고칠 수 있다",
      "scope": "rtl/, tb/, vectors/"
    },
    {
      "id": "R2",
      "rule": "LLM은 test를 추가할 수 있다",
      "scope": "tb/, sim/"
    },
    {
      "id": "R3",
      "rule": "LLM은 coverage gap을 채울 수 있다",
      "scope": "tb stimulus, vectors/"
    },
    {
      "id": "R4",
      "rule": "LLM은 spec/FL/coverage/perf target을 바꾸려면 change request 필수",
      "scope": "yaml/, model/, cov/"
    },
    {
      "id": "R5",
      "rule": "사람 승인 전에는 golden artifact 변경 금지",
      "scope": "model/functional_model.py, model/cycle_model.py, cov/fl_fcov_plan.json, cov/cl_fcov_plan.json"
    },
    {
      "id": "R6",
      "rule": "PASS의 의미는 항상 locked truth 기준으로만 판단",
      "scope": "all evidence rooted in SSOT + FL"
    }
  ],
  "human_gates": [
    {
      "id": "G1",
      "title": "Requirement 승인",
      "status": "pending",
      "evidence_required": [
        "atciic100_target/req/* exists, human-signed"
      ],
      "locked_artifacts": [
        "atciic100_target/req/"
      ]
    },
    {
      "id": "G2",
      "title": "Spec 승인",
      "status": "approved",
      "evidence_required": [
        "atciic100_target/yaml/atciic100_target.ssot.yaml exists, all 20 sections complete"
      ],
      "locked_artifacts": [
        "atciic100_target/yaml/atciic100_target.ssot.yaml"
      ]
    },
    {
      "id": "G3",
      "title": "Interface 승인",
      "status": "approved",
      "evidence_required": [
        "io_list section non-empty",
        "interface contract approved"
      ],
      "locked_artifacts": [
        "atciic100_target/yaml/atciic100_target.ssot.yaml#io_list"
      ]
    },
    {
      "id": "G4",
      "title": "FL golden model 승인",
      "status": "approved",
      "evidence_required": [
        "atciic100_target/model/functional_model.py exists",
        "atciic100_target/model/fl_model_check.json passed=true",
        "atciic100_target/model/model_signature.json fresh"
      ],
      "locked_artifacts": [
        "atciic100_target/model/functional_model.py",
        "atciic100_target/model/model_signature.json"
      ]
    },
    {
      "id": "G5",
      "title": "Coverage goal 승인",
      "status": "approved",
      "evidence_required": [
        "atciic100_target/cov/fl_fcov_plan.json exists with planned_before_rtl=true",
        "atciic100_target/cov/cl_fcov_plan.json exists when CL is required"
      ],
      "locked_artifacts": [
        "atciic100_target/cov/fl_fcov_plan.json",
        "atciic100_target/cov/cl_fcov_plan.json",
        "atciic100_target/cov/fcov_plan.json"
      ]
    },
    {
      "id": "G6",
      "title": "CL/performance target 승인",
      "status": "approved",
      "evidence_required": [
        "cycle_model.targets or latency declared",
        "synthesis.ppa_targets.frequency_mhz_min set when timing-sensitive"
      ],
      "locked_artifacts": [
        "atciic100_target/yaml/atciic100_target.ssot.yaml#cycle_model",
        "atciic100_target/model/cycle_model.py"
      ]
    },
    {
      "id": "G7",
      "title": "RTL architecture 방향 승인",
      "status": "pending",
      "evidence_required": [
        "atciic100_target/yaml/atciic100_target.ssot.yaml#sub_modules approved",
        "decomposition.json complete"
      ],
      "locked_artifacts": [
        "atciic100_target/yaml/atciic100_target.ssot.yaml#sub_modules",
        "atciic100_target/model/decomposition.json"
      ]
    },
    {
      "id": "G8",
      "title": "PPA/DFT trade-off 승인",
      "status": "approved",
      "evidence_required": [
        "atciic100_target/reports/ppa_sweep.json reviewed",
        "DFT coverage target set"
      ],
      "locked_artifacts": [
        "atciic100_target/yaml/atciic100_target.ssot.yaml#synthesis.ppa_targets",
        "atciic100_target/yaml/atciic100_target.ssot.yaml#dft"
      ]
    },
    {
      "id": "G9",
      "title": "Final sign-off",
      "status": "pending",
      "evidence_required": [
        "all gates G1..G8 approved",
        "all equivalence_goals.json goals not blocked",
        "fl_cl_rtl regression passed"
      ],
      "locked_artifacts": [
        "atciic100_target/golden/sign_off.json"
      ]
    }
  ],
  "llm_loops": [
    {
      "id": "L1",
      "title": "RTL correctness loop",
      "evidence_point": "FL expected vs RTL actual diff",
      "llm_action": "Patch RTL and rerun cocotb",
      "owner_on_fail": "rtl",
      "validator_path": "atciic100_target/sim/scoreboard_events.jsonl",
      "linked_goals": "EQ_TRANSACTION_*"
    },
    {
      "id": "L2",
      "title": "Module-level loop",
      "evidence_point": "scope.level=module equivalence diff at module boundary",
      "llm_action": "Patch only the owning RTL module",
      "owner_on_fail": "rtl",
      "validator_path": "atciic100_target/sim/module_scoreboard_*.jsonl",
      "linked_goals": "EQ_MODULE_*"
    },
    {
      "id": "L3",
      "title": "Coverage closure loop",
      "evidence_point": "coverage goals vs hit bins",
      "llm_action": "Add stimulus/tests; never weaken coverage goals",
      "owner_on_fail": "tb",
      "validator_path": "atciic100_target/cov/coverage.json",
      "linked_goals": "EQ_COVERAGE_*"
    },
    {
      "id": "L4",
      "title": "Lint/compile loop",
      "evidence_point": "DUT-only lint/compile diagnostics",
      "llm_action": "Patch RTL syntax/width/driver/style",
      "owner_on_fail": "rtl",
      "validator_path": "atciic100_target/lint/dut_lint.json",
      "linked_goals": "lint_compile criterion"
    },
    {
      "id": "L5",
      "title": "Assertion/protocol loop",
      "evidence_point": "SSOT interface/cycle assertion failure",
      "llm_action": "Patch RTL or TB monitor depending on classified owner",
      "owner_on_fail": "rtl|tb",
      "validator_path": "atciic100_target/sim/assertion_failures.jsonl",
      "linked_goals": "EQ_PROTOCOL_*, EQ_TIMING_*"
    },
    {
      "id": "L6",
      "title": "CL performance loop",
      "evidence_point": "cycle_model performance target vs measured latency/throughput",
      "llm_action": "Run parameter/architecture sweeps and propose tradeoff candidates",
      "owner_on_fail": "rtl|architect",
      "validator_path": "atciic100_target/reports/perf_sweep.json",
      "linked_goals": "EQ_TIMING_*, performance_cycle criterion"
    },
    {
      "id": "L7",
      "title": "PPA loop (Synthesis / DFT / PnR / STA / Power / Area)",
      "evidence_point": "synthesis/dft/pnr/sta/power reports vs PPA budget",
      "llm_action": "Propose RTL/architecture improvements per sub-stage; final acceptance is human",
      "owner_on_fail": "architect|human",
      "validator_path": "atciic100_target/reports/ppa_sweep.json",
      "sub_stages": [
        {
          "stage": "synthesis",
          "evidence": "atciic100_target/reports/synth/qor.json",
          "metrics": [
            "WNS",
            "TNS",
            "cell_area",
            "register_count",
            "est_power"
          ]
        },
        {
          "stage": "dft",
          "evidence": "atciic100_target/reports/dft/atpg.json",
          "metrics": [
            "fault_coverage",
            "pattern_count",
            "scan_chains",
            "scan_shift_power",
            "dft_area_overhead"
          ]
        },
        {
          "stage": "pnr",
          "evidence": "atciic100_target/reports/pnr/route.json",
          "metrics": [
            "post_route_WNS",
            "clock_skew",
            "wirelength",
            "cell_density",
            "congestion_overflow",
            "ir_drop_risk"
          ]
        },
        {
          "stage": "sta",
          "evidence": "atciic100_target/reports/sta/timing.json",
          "metrics": [
            "setup_slack",
            "hold_slack",
            "fmax_mhz"
          ]
        },
        {
          "stage": "power",
          "evidence": "atciic100_target/reports/power/power.json",
          "metrics": [
            "dynamic_mw",
            "leakage_mw",
            "toggle_hotspot"
          ]
        },
        {
          "stage": "area",
          "evidence": "atciic100_target/reports/pnr/area.json",
          "metrics": [
            "total_um2",
            "utilization_pct",
            "macro_area"
          ]
        }
      ],
      "feedback": "CL predicted vs measured: latency_ns=cycles*period; throughput=tx/cycle*Fmax; energy/op=power/ops; area_efficiency=throughput/area",
      "linked_goals": "EQ_PPA_*"
    },
    {
      "id": "L8",
      "title": "Regression minimization loop",
      "evidence_point": "Large failing test → minimal reproducer that still fails",
      "llm_action": "Bisect/shrink stimulus until a minimal vector reproduces the same failure; then patch RTL or escalate",
      "owner_on_fail": "tb|rtl",
      "validator_path": "atciic100_target/sim/min_repro_*.jsonl",
      "linked_goals": "any failing EQ_* goal"
    },
    {
      "id": "L9",
      "title": "Report / root-cause loop",
      "evidence_point": "Diff/log/coverage-miss/waveform evidence",
      "llm_action": "Synthesize fail_analysis.md with expected vs actual, likely cause, and suggested RTL patch — never modify FL/spec/coverage to make tests pass",
      "owner_on_fail": "tb|rtl|architect",
      "validator_path": "atciic100_target/reports/fail_analysis.md",
      "linked_goals": "any failing EQ_* goal"
    }
  ],
  "repo_layout": {
    "locked": [
      "yaml/",
      "model/",
      "cov/fl_fcov_plan.json",
      "cov/cl_fcov_plan.json",
      "verify/equivalence_goals.json"
    ],
    "llm_editable": [
      "rtl/",
      "tb/",
      "sim/",
      "vectors/",
      "assertions/",
      "reports/"
    ],
    "agent_runnable_validators": [
      "lint/",
      "sim/",
      "cov/coverage.json",
      "reports/ppa_sweep.json"
    ]
  },
  "summary": {
    "gates_total": 9,
    "gates_approved": 6,
    "gates_pending": 3,
    "gates_blocked": 0,
    "loops_total": 9,
