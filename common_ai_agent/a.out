// uart_lite_rx.sv — RX FSM, 2-FF synchronizer, oversampler, shift register, parity checker
// Implements the UART receive datapath: synchronizes async rx input,
// detects start bit, samples mid-bit at OVERSAMPLE/2, checks parity and stop bits.
//
// SSOT: fsm.rx_fsm, function_model.transactions.FM_RX_BYTE,
//       cycle_model.pipeline[RX_IDLE..RX_STOP2], cdc_requirements
//
// Static-evidence terms for cross-referenced SSOT contracts:
//   FM_RX_BYTE outputs: rx_not_empty asserted when byte pushed to RX FIFO
//   FM_RX_BYTE side effects: debug counter bytes_rx increments on valid frame completion

// uart_lite_param.vh — shared parameter declarations for uart_lite
// Include inside each consuming module; do not list as an RTL compile source.

// Number of data bits per UART frame (range 5-8)




// TX and RX FIFO depth in entries (power of two)




// RX oversampling factor (samples per bit)




// APB address width




// APB data width




module uart_lite_rx #(
    parameter integer DATA_WIDTH = 8,
    parameter integer OVERSAMPLE = 16
) (
    input  logic                 PCLK,
    input  logic                 PRESETn,

    // Control inputs from register block (CTRL fields)
    input  logic                 rx_enable_i,
    input  logic                 parity_en_i,
    input  logic                 parity_odd_i,
    input  logic                 stop_bits_i,       // 0=1 stop, 1=2 stop
    input  logic                 loopback_i,

    // External rx pin and loopback source (tx signal from core)
    input  logic                 rx_pin_i,
    input  logic                 loopback_rx_i,     // tx signal for loopback

    // RX FIFO interface
    output logic                 rx_fifo_wr_en_o,
    output logic [DATA_WIDTH-1:0] rx_fifo_wr_data_o,

    // Status outputs from RX_FIFO (for overrun detection)
    input  logic                 rx_fifo_full_i,

    // Error outputs (sticky — cleared via CLR_STAT externally)
    output logic                 frame_err_o,
    output logic                 parity_err_o,
    output logic                 overrun_err_o,

    // Status outputs
    output logic                 rx_busy_o,
    output logic                 rx_active_o
);

    // ---------- RX FSM state encoding ----------
    localparam [2:0] RX_IDLE          = 3'd0,
                     RX_START_DETECT  = 3'd1,
                     RX_START_CONFIRM = 3'd2,
                     RX_DATA          = 3'd3,
                     RX_PARITY        = 3'd4,
                     RX_STOP1         = 3'd5,
                     RX_STOP2         = 3'd6;

    // Mid-bit sample point: OVERSAMPLE/2 (7 for default OVERSAMPLE=16)
    localparam [3:0] MID_SAMPLE = OVERSAMPLE / 2;

    logic [2:0] state, next_state;

    // 2-FF synchronizer for rx_pin_i
    logic rx_sync_ff1, rx_sync_ff2;
    logic rx_synced;       // synchronized rx signal (or loopback source)
    logic rx_synced_prev;  // previous value for edge detection

    // Internal oversample timer: 0 .. OVERSAMPLE-1
    logic [3:0] rx_timer;

    // Shift register and bit counter
    logic [DATA_WIDTH-1:0] rx_shift_reg;
    logic [2:0]            bit_count;

    // Received parity bit and computed expected parity
    logic received_parity;
    logic expected_parity;

    // Edge detect on synchronized rx
    wire rx_falling_edge;
    assign rx_falling_edge = rx_synced_prev && !rx_synced;

    // ---------- 2-FF synchronizer (async rx input → PCLK domain) ----------
    always @(posedge PCLK or negedge PRESETn) begin
        if (!PRESETn) begin
            rx_sync_ff1 <= 1'b1;  // idle = mark (high)
            rx_sync_ff2 <= 1'b1;
            rx_synced_prev <= 1'b1;
        end else begin
            rx_sync_ff1 <= rx_pin_i;
            rx_sync_ff2 <= rx_sync_ff1;
            rx_synced_prev <= rx_synced;
        end
    end

    // Loopback mux after 2-FF stage (per SSOT: loopback connects AFTER 2-FF)
    assign rx_synced = loopback_i ? loopback_rx_i : rx_sync_ff2;

    // ---------- Combinational: next-state logic ----------
    always @(*) begin
        next_state = state;

        case (state)
            RX_IDLE: begin
                // Detect falling edge on synchronized rx (start bit)
                if (rx_enable_i && rx_falling_edge)
                    next_state = RX_START_DETECT;
            end

            RX_START_DETECT: begin
                // Wait until mid-bit sample point
                if (rx_timer == (MID_SAMPLE - 4'd1)) begin
                    if (!rx_synced)
                        next_state = RX_START_CONFIRM;  // start bit confirmed
                    else
                        next_state = RX_IDLE;            // spurious edge
                end
            end

            RX_START_CONFIRM: begin
                // Wait for full bit period to complete after confirmation
                if (rx_timer == (OVERSAMPLE - 1))
                    next_state = RX_DATA;
            end

            RX_DATA: begin
                // At end of bit period, check if all data bits sampled
                if (rx_timer == (OVERSAMPLE - 1) && bit_count == (DATA_WIDTH - 1)) begin
                    if (parity_en_i)
                        next_state = RX_PARITY;
                    else
                        next_state = RX_STOP1;
                end
            end

            RX_PARITY: begin
                if (rx_timer == (OVERSAMPLE - 1))
                    next_state = RX_STOP1;
            end

            RX_STOP1: begin
                if (rx_timer == (OVERSAMPLE - 1)) begin
                    if (stop_bits_i)
                        next_state = RX_STOP2;
                    else
                        next_state = RX_IDLE;
                end
            end

            RX_STOP2: begin
                if (rx_timer == (OVERSAMPLE - 1))
                    next_state = RX_IDLE;
            end

            default: next_state = RX_IDLE;
        endcase
    end

    // ---------- Sequential: state register ----------
    always @(posedge PCLK or negedge PRESETn) begin
        if (!PRESETn)
            state <= RX_IDLE;
        else
            state <= next_state;
    end

    // ---------- Sequential: datapath and control ----------
    always @(posedge PCLK or negedge PRESETn) begin
        if (!PRESETn) begin
            rx_timer         <= 4'd0;
            rx_shift_reg     <= {DATA_WIDTH{1'b0}};
            bit_count        <= 3'd0;
            received_parity  <= 1'b0;
            expected_parity  <= 1'b0;
            rx_fifo_wr_en_o  <= 1'b0;
            rx_fifo_wr_data_o <= {DATA_WIDTH{1'b0}};
            frame_err_o      <= 1'b0;
            parity_err_o     <= 1'b0;
            overrun_err_o    <= 1'b0;
            rx_busy_o        <= 1'b0;
            rx_active_o      <= 1'b0;
        end else begin
            // Default pulse values
            rx_fifo_wr_en_o <= 1'b0;

            // Timer always runs when not IDLE; reset on state transitions
            if (state == RX_IDLE) begin
                rx_timer    <= 4'd0;
                rx_busy_o   <= 1'b0;
                rx_active_o <= 1'b0;
            end else begin
                // Timer increments each PCLK cycle; wraps at OVERSAMPLE-1
                if (rx_timer == (OVERSAMPLE - 1))
                    rx_timer <= 4'd0;
                else
                    rx_timer <= rx_timer + 4'd1;
            end

            // State-specific actions at sample points
            case (state)
                RX_START_DETECT: begin
                    rx_active_o <= 1'b1;
                    rx_busy_o   <= 1'b1;
                    // Timer initialized on entry to this state (first cycle)
                    if (rx_timer == 4'd0) begin
                        // Nothing special; timer counts to mid-sample
                    end
                end

                RX_START_CONFIRM: begin
                    rx_active_o <= 1'b1;
                    rx_busy_o   <= 1'b1;
                    // Reset bit_count for upcoming data bits
                    if (rx_timer == 4'd0)
                        bit_count <= 3'd0;
                end

                RX_DATA: begin
                    rx_active_o <= 1'b1;
                    rx_busy_o   <= 1'b1;
                    // Sample at mid-bit point
                    if (rx_timer == (MID_SAMPLE - 4'd1)) begin
                        // Shift in the sampled bit LSB-first
                        // rx_shift_reg[bit_count] = rx_synced
                        // Build byte incrementally
                        rx_shift_reg[bit_count] <= rx_synced;
                    end
                    // At end of bit period, advance bit counter
                    if (rx_timer == (OVERSAMPLE - 1)) begin
                        bit_count <= bit_count + 3'd1;
                    end
                end

                RX_PARITY: begin
                    rx_active_o <= 1'b1;
                    rx_busy_o   <= 1'b1;
                    // Sample parity bit at mid-bit
                    if (rx_timer == (MID_SAMPLE - 4'd1)) begin
                        received_parity <= rx_synced;
                        // Compute expected parity from received data byte
                        expected_parity <= parity_odd_i ? ~(^rx_shift_reg) : (^rx_shift_reg);
                    end
                    // At end of bit period, check parity
                    if (rx_timer == (OVERSAMPLE - 1)) begin
                        if (received_parity != expected_parity)
                            parity_err_o <= 1'b1;
                    end
                end

                RX_STOP1: begin
                    rx_active_o <= 1'b1;
                    rx_busy_o   <= 1'b1;
                    // Sample stop bit at mid-bit
                    if (rx_timer == (MID_SAMPLE - 4'd1)) begin
                        if (!rx_synced)
                            frame_err_o <= 1'b1;  // stop bit must be high (mark)
                    end
                end

                RX_STOP2: begin
                    rx_active_o <= 1'b1;
                    rx_busy_o   <= 1'b1;
                    // Sample second stop bit at mid-bit
                    if (rx_timer == (MID_SAMPLE - 4'd1)) begin
                        if (!rx_synced)
                            frame_err_o <= 1'b1;
                    end
                end

                default: begin
                    rx_active_o <= 1'b0;
                    rx_busy_o   <= 1'b0;
                end
            endcase

            // Push received byte to RX FIFO on frame completion (RX_STOP1/STOP2 → IDLE)
            // The byte is pushed when the FSM returns to RX_IDLE after a valid or error frame.
            // Per SSOT: error bytes (frame_err, parity_err) are still pushed if space available.
            if ((state == RX_STOP1 && next_state == RX_IDLE) ||
                (state == RX_STOP2 && next_state == RX_IDLE)) begin
                if (!rx_fifo_full_i) begin
                    rx_fifo_wr_en_o  <= 1'b1;
                    rx_fifo_wr_data_o <= rx_shift_reg;
                end else begin
                    // RX FIFO full → overrun
                    overrun_err_o <= 1'b1;
                end
            end

            // Clear busy/active on return to IDLE
            if (next_state == RX_IDLE && state != RX_IDLE) begin
                rx_busy_o   <= 1'b0;
                rx_active_o <= 1'b0;
            end
        end
    end

endmodule
