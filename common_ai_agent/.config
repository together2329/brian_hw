# Common AI Agent Environment Variables
# Copied from .env.example and populated with your keys

# ============================================================
# LLM Provider Configuration
# ============================================================
# Provider: openai (default) | azure | anthropic | openrouter | zai
# Default: openai
#
# Azure OpenAI + Responses API settings are configured in .env
# See .env.example for documentation and examples.

# ============================================================
# Opencode OAuth (ChatGPT / Codex routing) — gpt-5.x switch
# ============================================================
# When TRUE, src/config.py auto-runs activate_opencode_oauth() at boot:
#   - swaps BASE_URL → CODEX_BASE_URL
#   - swaps API_KEY → ChatGPT-OAuth access token
#   - if MODEL_NAME does NOT start with "gpt-5", overrides it to OPENCODE_MODEL
#     (default "gpt-5.5") — this is why gpt-5.5 was being treated as default
#     even though .env had LLM_MODEL_NAME=glm-5.1.
# Set FALSE to honour the .env LLM_PROFILE / LLM_MODEL_NAME (glm-5.1, etc.).
# Flip to TRUE only when you actually want to run on gpt-5.x via Codex OAuth.
# Default in src/config.py: "true" — explicitly off here so GLM works as set.
USE_OPENCODE_OAUTH=true
# When OPENCODE_OAUTH=true, this picks the gpt-5* model. Used only at activation.
OPENCODE_MODEL=gpt-5.5

# OpenAI/Azure Responses API toggle.
# Keep this false globally for Z.AI / GLM / DeepSeek / OpenRouter profiles that
# only serve /chat/completions. Azure reasoning-capable deployments route to
# /openai/v1/responses automatically when LLM_PROVIDER=azure and
# REASONING_MODE is not off, even if USE_RESPONSES_API stays false.
# activate_opencode_oauth() sets this true at runtime; deactivate_opencode_oauth()
# does NOT reset it (bug in src/config.py:431). This false here is the
# defensive override so a leftover OAuth session can't poison subsequent calls.
# Default to Responses API so Azure/OpenAI reasoning.effort is actually used.
# Turn this off only for providers that do not expose /responses.
USE_RESPONSES_API=true

# ============================================================
# Common AI Agent Settings
# ============================================================
# Codex app-server is the checked-in local default engine for ATLAS codex mode.
# Keep ATLAS's native OAG prompt/tool injection off here; Codex reads the repo
# AGENTS/skills itself through its app-server runtime. Operators can still opt
# back into native OAG by setting OAG_MODE=1 in their shell/local env.
CODEX_BRIDGE=1
CODEX_BRIDGE_HOME=../../ontology_ip_agent/.codex
CODEX_BRIDGE_OAG_ROOT=../../ontology_ip_agent
CODEX_BRIDGE_ENABLE_HOOKS=1
CODEX_BRIDGE_RUN_OAG_HOOKS=1
CODEX_BRIDGE_STAGE_DOT_CODEX=1
CODEX_BRIDGE_TRUST_THREAD_CWD=1
CODEX_BRIDGE_BYPASS_HOOK_TRUST=1
CODEX_BRIDGE_OAG_MODE=0
OAG_MODE=0

# Root separation for split ATLAS/IP workspaces.
# ATLAS_SOURCE_ROOT points to this common_ai_agent checkout. Keep it relative
# so cloned checkouts do not inherit one machine's absolute path.
# ATLAS_WORKFLOW_ROOT points to common_ai_agent/workflow (scripts/templates).
# ATLAS_PROJECT_ROOT points to the parent directory that contains IP dirs.
# ATLAS_IP_ROOT optionally pins one active IP directory.
# CLI equivalents:
#   python -m src.atlas_ui --workflow-root "$PWD/workflow" --root /path/to/IP_PARENT
#   python -m src.atlas_ui --workflow-root "$PWD/workflow" --ip-root /path/to/IP_PARENT/uart_v2
# Leave ATLAS_PROJECT_ROOT / ATLAS_IP_ROOT unset unless this backend should
# pin exactly one project or IP. The UI defaults project root to the launch cwd.
ATLAS_SOURCE_ROOT=.
ATLAS_WORKFLOW_ROOT=${ATLAS_SOURCE_ROOT}/workflow
#ATLAS_PROJECT_ROOT=.
#ATLAS_IP_ROOT=uart_v2

# Wikis: the dev wiki (doc/wiki) is derived from --workflow-root /
# ATLAS_WORKFLOW_ROOT (its sibling), so no separate var is needed. The external
# previous-project RTL DB pointer (ATLAS_RTL_DB_WIKI) is a machine-specific path
# and lives in .env (gitignored); scaffold_ip bakes its resolved value into each
# new IP's wiki/workflow-runbook.md at new-ip time.
#
# External DB override (the source need NOT be RTL, and need NOT use ATLAS's wiki
# structure). wiki_query(ip="external-db") — aliases: rtl-db / andes — plugs a foreign
# source in without ATLAS code changes. Prefer the ATLAS_EXTERNAL_DB_* names; the legacy
# ATLAS_RTL_DB_* names still work as fallbacks. (all go in .env):
#   ATLAS_EXTERNAL_DB_WIKI=/abs/wiki            # a wiki dir (markdown + _graph.json)
#   ATLAS_EXTERNAL_DB_BUILDER=/abs/builder.py   # ATLAS runs `<builder> --wiki <root>`
#                                               # instead of build_graph.py; writes
#                                               # <root>/_graph.json (wiki_graph.v1).
#                                               # See scripts/example_external_rtl_db_builder.py.
#   ATLAS_EXTERNAL_DB_NO_REBUILD=1              # trust an externally-produced _graph.json;
#                                               # ATLAS never (re)builds or clobbers it.
#   ATLAS_EXTERNAL_DB_QUERY=/abs/query_adapter  # MAX freedom: external owns the WHOLE
#                                               # query. ATLAS pipes {ip,topic,depth,
#                                               # max_nodes} as JSON on stdin and returns
#                                               # stdout verbatim — no wiki/_graph schema.
#                                               # Any language/transport (files, DB, HTTP).
#                                               # See scripts/example_external_rtl_db_query.py.
# The `external-db` skill (skills/external-db/) auto-triggers on reuse/reference keywords
# and routes the agent to wiki_query(ip="external-db") — data-source-agnostic (works with
# any hook above). External tools can also be added via .mcp.json (ENABLE_MCP).

# Rate limiting (seconds between API calls, 0 to disable)
# Default: 5
RATE_LIMIT_DELAY=0

# Maximum ReAct loop iterations
# Default: 100
MAX_ITERATIONS=1000

# API timeout in seconds (how long to wait for API response)
# Default: 60
API_TIMEOUT=300
STREAM_API_TIMEOUT=3600
STREAM_INACTIVITY_TIMEOUT=1200
NONSTREAM_API_TIMEOUT=600

# Save conversation history
# Default: true
SAVE_HISTORY=true
HISTORY_FILE=conversation_history.json

# Debug mode - show detailed parsing and execution info
# Default: false
DEBUG_MODE=false
#DEBUG_MODE=true

# Performance tracking - print timing for each ReAct loop phase
# Shows: [PERF] compress / build_prompt / before_llm_hook / llm / parse / tool/<name>
# Default: false
#PERF_TRACKING=true
PERF_TRACKING=false

# Show token usage stats after each LLM response (✽ in X · out Y · sum Z tokens)
# Default: true
#SHOW_TOKEN_STATS=true
SHOW_TOKEN_STATS=false
# Show token stats in sidebar instead of main log (TUI only); hides them from main display
# Default: true
SHOW_TOKEN_STATS_SIDEBAR=true

# Include LLM reasoning (<think> tags & reasoning tokens) in message context
# true  = reasoning is stored in history so the model can reference prior thoughts
# false = reasoning is display-only and stripped before storing (saves context)
# Default: false
REASONING_IN_CONTEXT=false
REASONING_DISPLAY=true

# Streaming mode: true = token-by-token display, false = wait for full response
# Non-streaming cleanly separates reasoning/content (no bleed artifacts)
# Default: true
#ENABLE_STREAMING=false
ENABLE_STREAMING=true

# Enable Markdown rendering in UI (Live highlighting, tables, code blocks)
# Set to false to use raw line-by-line terminal output for maximum performance
# Default: true
ENABLE_MARKDOWN_RENDER=true

# Tool result preview settings
TOOL_RESULT_PREVIEW_LINES=3
TOOL_RESULT_PREVIEW_CHARS=300
# Show syntax-highlighted detail preview for read/grep/list tools (default: true)
# Set false to show plain brief summary only
DISPLAY_TOOL_DETAIL=true

# Human-in-the-loop: allow typing messages while agent is running.
# When true, input submitted during agent execution is injected as a user
# message between iterations (after tools finish, before next LLM call).
# Default: false
ENABLE_HUMAN_IN_THE_LOOP=true

# Large File Handling
MAX_OBSERVATION_CHARS=20000
LARGE_FILE_PREVIEW_LINES=100

# ============================================================
# RTL dialect (rtl-gen / ssot-gen / scaffold_ip)
# ============================================================
# Controls the Verilog dialect emitted by the RTL generator workflow
# and the file extension created by the scaffold_ip tool.
#   verilog_2001       — IEEE 1364, file ext .v, wire/reg, always @(...)
#                        (default — narrower language surface, universal
#                        toolchain support, easier to audit)
#   systemverilog_2012 — IEEE 1800, file ext .sv, logic, always_ff/always_comb
#                        (use only when an IP needs SV-specific constructs)
# Project-wide convention (independent of this flag): `package`,
# `endpackage`, `import`, `interface`, `modport` are FORBIDDEN in RTL even
# in SV mode. Use module ports + localparam blocks for shared constants.
RTL_DIALECT=verilog_2001

# ============================================================
# PDK / EDA library paths
# ============================================================
# Relative paths are resolved from common_ai_agent/, not the shell cwd, so
# workflows can be launched from any IP workspace and still inherit readable
# SKY130_* paths.
PDK_ROOT=pdk
SKY130_PDK_ROOT=pdk/sky130
PDK_LIB_PATH=pdk/sky130/lib
SKY130_LIB=pdk/sky130/lib/sky130_fd_sc_hd__ss_100C_1v40.lib
SKY130_TLEF=pdk/sky130/lef/sky130_fd_sc_hd.tlef
SKY130_LEF=pdk/sky130/lef/sky130_fd_sc_hd_merged.lef
SKY130_TRACKS=pdk/sky130/make_tracks.tcl
SKY130_RCX_RULES=pdk/sky130/rcx_patterns.rules

# ============================================================
# Context Management
# ============================================================
# Token limit for the model context window
# Set this to your model's actual context window size.
# e.g. 131072 for 128K models, 200000 for Claude/GLM-5.1, 1000000 for Gemini 1M
# Set to model's actual context window so compute_safe_max_tokens() can
# dynamically cap output as context fills up (prevents reasoning overflow).
# GLM-5.1: 200K context window
#MAX_CONTEXT_TOKENS=50000
MAX_CONTEXT_TOKENS=200000
#MAX_CONTEXT_TOKENS=256000
#MAX_CONTEXT_TOKENS=1000000

# Maximum visible output tokens (content of LLM responses).
# Default in code: 32000. Agent saw "max_tokens=48000 limit reached" when
# writing large wrapper.sv with many AXI ports — the truncation corrupts
# tool_call args and triggers the 1214 / loop-detection cascade.
# Hard ceiling in llm_client._MAX_OUTPUT_TOKENS_HARD_CAP = 64000.
# Bumped here to give large file writes (multi-port wrappers, full TBs)
# room to land in one shot. If your provider rejects at 60k, lower this.
MAX_OUTPUT_TOKENS=48000

# Maximum reasoning/thinking tokens (GLM, DeepSeek, GPT-5.x, o-series).
# For reasoning models, these tokens count against max_tokens alongside content.
# Setting this expands the total budget so reasoning doesn't eat into content:
#   effective max_tokens = MAX_OUTPUT_TOKENS + MAX_REASONING_TOKENS
# Set to 0 to disable the expansion (max_tokens = MAX_OUTPUT_TOKENS only).
# Recommended: 8000-16000 to give the model room to think AND produce content.
# NOTE: with MAX_OUTPUT_TOKENS=48000 + MAX_REASONING_TOKENS=16000 = 64000
# (= hard cap). If you bump output further, drop reasoning to fit under 64k.
MAX_REASONING_TOKENS=16000

# Responses reasoning effort for GPT-5.x / o-series models.
# Local env var name is REASONING_MODE, but the API field is reasoning.effort.
# Options: none | minimal | low | medium | high | xhigh
# - none:   request no reasoning effort when the model supports it
# - minimal: minimum reasoning
# - low:    fastest official reasoning tier
# - medium: balanced speed/cost
# - high:   deeper reasoning, slower, more expensive
# - xhigh:  extra-high reasoning on supported models
REASONING_MODE=xhigh
# Backward-compatible alias for older code paths
REASONING_EFFORT=xhigh
# Ask Responses-compatible providers for a visible reasoning summary when supported
RESPONSES_REASONING_SUMMARY=true

# Threshold to trigger compression (0.0 to 1.0)
# Default: 0.8 (80%)
COMPRESSION_THRESHOLD=0.8

# Enable/Disable compression
# Default: true
ENABLE_COMPRESSION=true

# Compression mode: 'single' or 'chunked'
COMPRESSION_MODE=single

# Chunk size for chunked compression
COMPRESSION_CHUNK_SIZE=10

# Number of recent messages to keep unchanged during compression
#COMPRESSION_KEEP_RECENT=4
COMPRESSION_KEEP_RECENT=4
# Number of most-recently-accessed paths to embed in compression system msg (0=disable)
COMPRESSION_TOOL_CALL_PATHS=0
ENABLE_TURN_PROTECTION=false

# LLM retry count on empty/timeout response (0 = no retry)
LLM_RETRY_COUNT=1

# ============================================================
# Native Tool Call Support (Function Calling)
# ============================================================
# When true: uses structured JSON tool_calls API instead of ReAct text parsing.
# Requires model to support OpenAI-compatible tools API (most GPT/Claude/Gemini do).
# false = classic ReAct text mode (Action: tool_name(arg=value))
# Default: false
#ENABLE_NATIVE_TOOL_CALLS=false
ENABLE_NATIVE_TOOL_CALLS=true
# Compact tool schemas for servers that reject large payloads (HTTP 500 with tools=)
# Truncates descriptions to first sentence — reduces schema from ~18KB to ~4KB
TOOL_SCHEMA_COMPACT=true

# Enable Smart Compression (selective preservation)
# Default: true
ENABLE_SMART_COMPRESSION=true

# Pre-compression analysis: LLM identifies critical context before compressing.
# Adds one extra LLM call but produces more context-aware summaries.
# Default: false
# COMPRESSION_PRE_ANALYSIS=true

# Todo work log — LLM appends progress notes via todo_note()
# Notes survive compression, shown in review/rejection prompts and /todo -v
# Default: true
ENABLE_TODO_NOTES=true

# ============================================================
# Prompt Caching & KV Cache Configuration
# ============================================================
# Enable Anthropic Prompt Caching (manual control only)
# Default: false
# NOTE: 90% cost reduction on cached tokens!
ENABLE_PROMPT_CACHING=true

# Caching Optimization Mode
# Options: legacy | optimized
# - legacy: Single-string system message (current behavior, safe fallback)
# - optimized: Multi-block system message (40-50% additional cost reduction!)
# Default: legacy
# Recommended: optimized (when using Anthropic Claude models)
CACHE_OPTIMIZATION_MODE=optimized

# Note: Store parameter (KV cache/prompt caching) is automatically enabled for:
# - OpenAI (gpt-5.x, o-series): Responses API with prompt caching
# - GLM models: Chat Completions API with KV cache support
# - OpenRouter with these backends: automatic routing to correct caching mechanism

# ============================================================
# Multiline Input (prompt_toolkit)
# ============================================================
# Enter=줄바꿈, ESC→Enter 또는 Ctrl+D=전송
# Default: false (standard single-line input)
ENABLE_MULTILINE_INPUT=true

# ──────────────────────────────────────────────
# UI Mode: textual | web | atlas
# textual = terminal-based TUI (Textual)
# web     = legacy browser UI (FastAPI + SSE)
# atlas   = new Atlas frontend (FastAPI + WebSocket, React + Babel-in-browser)
#UI_MODE=textual
#UI_MODE=web
UI_MODE=atlas
# Web UI port (only used when UI_MODE=web)
WEB_UI_PORT=8080
# Atlas UI port (only used when UI_MODE=atlas)
ATLAS_UI_PORT=8765

# Atlas UI center column layout (only used when UI_MODE=atlas)
#   classic = chat feed with inline ask_user prompt (original behavior)
#   tabbed  = Chat / Preview / Q&A tabs in the center column;
#             auto-switches to Q&A on ask_user, back to Chat after submit.
#             Mirrors the textual UI's batched ask_user breadcrumb tabs.
# Default: classic
#ATLAS_CENTER_LAYOUT=classic
ATLAS_CENTER_LAYOUT=tabbed

# Atlas chat feed cleanup layer
#   true  = concise reasoning + cleaned todo/tool summaries
#   false = rawer reasoning/tool output for transcript debugging
ATLAS_CHAT_FEED_SUMMARY=true
#
# UI/API output glyph compatibility:
# set to true when terminal/font can render Unicode poorly (Linux terminals,
# legacy Windows console). This forces ASCII symbols for blocked/passed/running.
#ATLAS_ASCII_OUTPUT=true

# Multi-user namespace seeding from the requesting client's IPv4.
# When true, /healthz returns client_ip + user_session = "u-<ipv4-dashed>"
# and the frontend seeds localStorage on first visit so each LAN
# user gets their own .session/<u-...>/<ip>/<workflow>/ tree without
# a login screen. Off by default so single-user installs keep the
# legacy "default" namespace unchanged. Flip to true when running
# multiple textual_main.py backends or one shared instance for a LAN.
ATLAS_MULTI_USER=true

# Atlas execution mode.
# Default to single-worker so local installs do not require the orchestrator IPC
# worker mesh. The UI/API mode picker is locked to single-worker for now.
# To re-enable orchestrator, clear ATLAS_EXEC_MODE_LOCK and uncomment the
# profile below before restarting the backend.
ATLAS_EXEC_MODE=single-worker
ATLAS_DEFAULT_EXEC_MODE=single-worker
ATLAS_ORCHESTRATOR_MODE=0
ATLAS_SINGLE_MAIN_LOOP=1
ATLAS_EXEC_MODE_LOCK=1
ATLAS_ORCHESTRATOR_TRANSPORT=ipc
ATLAS_WORKER_TRANSPORT=ipc
ATLAS_MULTI_USER_PROC=true
ATLAS_SESSION_WORKER_KEEPALIVE=true
ATLAS_RUN_MODE=engineering

# Orchestrator profile:
# ATLAS_EXEC_MODE_LOCK=0
# ATLAS_EXEC_MODE=orchestrator
# ATLAS_DEFAULT_EXEC_MODE=orchestrator
# ATLAS_ORCHESTRATOR_MODE=1
# ATLAS_SINGLE_MAIN_LOOP=0

# Session-centered runtime DB routing.
# Keep this as policy only. Do not set local filesystem paths such as
# ATLAS_ROOT, ATLAS_DB_PATH, ATLAS_CONTROL_DB_PATH, or ATLAS_RUNTIME_DB_ROOT in
# the shared project config; let the launcher/root argument or local shell/env
# choose those paths. This prevents a checked-in local override from being
# parsed literally or forcing another user's workspace.
ATLAS_RUNTIME_DB_MODE=session

# ============================================================
# Feature Flags
# ============================================================
ENABLE_VERILOG_TOOLS=true

# ── pyslang (SystemVerilog AST linter) ──────────────────────────────────────
# pyslang provides IEEE 1800-2017 compliant SV parsing with no external binary.
# Install: pip install pyslang
# If enabled and pyslang is importable, it is used as the primary Verilog linter
# and powers sv_get_ports / sv_get_hierarchy / sv_compile tools.
# If pyslang is not installed, falls back to VERILOG_SIMULATOR (vcs/iverilog/verilator).
ENABLE_PYSLANG=true

# Verilog simulator fallback (used when pyslang unavailable or ENABLE_PYSLANG=false)
# Options: vcs | iverilog | verilator
VERILOG_SIMULATOR=vcs
ENABLE_SKILL_SYSTEM=true
CMUX_ENABLE=false
TMUX_ENABLE=false

# Proactive Mode
PROACTIVE_ENABLED=false
#PROACTIVE_ENABLED=false
PROACTIVE_IDLE_SECONDS=120
PROACTIVE_MESSAGE=🤔 Still here? Need help with anything?

#ENABLE_WEB_TOOLS=false
ENABLE_WEB_TOOLS=true
FIRECRAWL_API_URL=http://localhost:3002
FIRECRAWL_TIMEOUT=60

# Image Read — analyze images using vision-capable models
# Pinned to Z.AI GLM regardless of main LLM provider so image reading
# works whether LLM_BASE_NAME is gpt-*, deepseek-*, claude-*, or anything else.
# All settings here (no .env split) — ergonomic single-file config.
# NOTE: vision endpoint is /api/paas/v4 (NOT /api/coding/paas/v4 — coding
# subpath only serves chat completions for coding GLM, not vision models).
ENABLE_IMAGE_READ=true
IMAGE_READ_BASE_URL=https://api.z.ai/api/paas/v4
IMAGE_READ_API_KEY=
IMAGE_READ_MODEL=gpt-5.5
IMAGE_READ_MAX_SIZE=8
IMAGE_READ_TIMEOUT=120

# MCP Integration — edit .mcp.json to add servers, secrets go in .env
ENABLE_MCP=false
MCP_CONFIG_PATH=.mcp.json

# GLM-5/5.1 Thinking Mode
# GLM_THINKING_TYPE: enabled (default) | disabled
# GLM_CLEAR_THINKING: true = clear each turn (default) | false = preserved thinking
GLM_THINKING_TYPE=enabled
GLM_CLEAR_THINKING=false

# Lines to preview when write_file runs (parallel or sequential). 0 = disable
WRITE_PREVIEW_LINES=100

# Max lines shown for edit/replace results (0 = disable, show brief). Default: all
EDIT_PREVIEW_MAX_LINES=1000

# Optional path to modifiable_ai_agent directory (used by cmux_restart_modifiable / tmux_restart_modifiable)
#MODIFIABLE_DIR=../brian_hw_modifiable/common_ai_agent

# Todo stagnation limit (no-action turns before stopping)
# Default: 50  — lowered to 5: BLOCKED tasks (e.g. external SSOT patch needed)
# should hand control back to the human fast instead of looping silently.
TODO_STAGNATION_LIMIT=5

# Maximum rejection count before livelock detection triggers
# A task rejected more than this many times is flagged as stuck.
# Default: 50 — set to 6 (paired with EXECUTION_NO_ACTION_RETRY_LIMIT).
MAX_REJECTION_LIMIT=6

# Consecutive no-Action (prose-only) replies allowed while a todo is unfinished
# before the execution no-action guard stops the loop and waits for input.
# Code default: 3 — raised to 6 so legitimate summary/handoff prose does not
# stop the auto-driven todo loop too eagerly.
EXECUTION_NO_ACTION_RETRY_LIMIT=6

# Auto-advance threshold: turns without todo_update before force-completing current task
# Default: 5 (fallback: TODO_STAGNATION_LIMIT // 10) — explicit 3 for tight loop break.
TODO_AUTO_ADVANCE_THRESHOLD=3

# Consecutive text-only turns (no tool call) allowed while todos are incomplete
# before breaking the loop and waiting for user input.
# Default: 50 — lowered to 5 so BLOCKED notes don't spin without action.
TODO_TEXT_ONLY_LIMIT=5

# ============================================================
# Project Rules (.UPD_RULE.md) Injection
# ============================================================
# Inject .UPD_RULE.md BEFORE default RULES in system prompt (takes precedence).
# true  = PROJECT RULES override defaults like "MANDATORY parallel execution"
# false = old behavior (appended after, may be ignored by model)
# Default: true
UPD_RULE_PRIORITY_INJECT=false

# Re-inject .UPD_RULE.md into each task continuation reminder (every turn).
# true  = model is reminded of project rules alongside each todo task
# false = project rules only appear in system prompt (may fade in long sessions)
# Default: false
UPD_RULE_PERIODIC_INJECT=false

# ============================================================
# Claude Flow (Plan Mode) — off | auto | always
# ============================================================
CLAUDE_FLOW_MODE=off

# ============================================================
# Plan Mode (Interactive)
# ============================================================
# Plan output directory
PLAN_DIR=~/.common_ai_agent/plans

# Plan mode debug output
PLAN_MODE_DEBUG=true
PLAN_MODE_DEBUG_FULL=false
PLAN_MODE_STREAM=true

# Context injection for Plan Mode: full | summary | recent
PLAN_MODE_CONTEXT_MODE=full
PLAN_MODE_CONTEXT_RECENT_N=12
PLAN_MODE_CONTEXT_INCLUDE_SYSTEM=false
# Max chars for injected context (0 = no limit)
PLAN_MODE_CONTEXT_MAX_CHARS=0

# Force gpt-5* models (non-codex) to use /chat/completions instead of /responses
# Default: false
FORCE_CHAT_COMPLETIONS_GPT5=false

# Max todo_write calls allowed in plan mode before blocking further rewrites
# Default: 10
PLAN_TODO_WRITE_MAX=10

# Explore agents configuration
# Number of parallel explore agents to spawn (1-5)
PLAN_MODE_EXPLORE_COUNT=3
# Enable parallel exploration (highly recommended)
PLAN_MODE_PARALLEL_EXPLORE=true

# ============================================================
# Timeout Configuration for Agents
# ============================================================
# Timeout for parallel action batch (seconds)
# Default: 30 (too short for complex exploration)
# Recommended: 120 for plan mode with explore agents
REACT_ACTION_TIMEOUT=120

# Timeout for each sub-agent (seconds)
# Default: 60
# Recommended: 120 for complex exploration tasks
SUB_AGENT_TIMEOUT=120

# ============================================================
# Memory System Configuration
# ============================================================
# Enable/Disable memory system
ENABLE_MEMORY=false
MEMORY_DIR=.memory
ENABLE_AUTO_EXTRACT=true

# ============================================================
# Graph Lite Configuration
# ============================================================
# Enable/Disable graph system
ENABLE_GRAPH=false
GRAPH_AUTO_EXTRACT=true
GRAPH_SEARCH_LIMIT=5
GRAPH_SIMILARITY_THRESHOLD=0.5
GRAPH_EXTRACTION_MESSAGES=10

# ============================================================
# A-MEM Configuration (Auto-Linking)
# ============================================================
AMEM_SIMILARITY_THRESHOLD=0.5
AMEM_MAX_CANDIDATES=10
AMEM_LINK_TEMPERATURE=0.3

# ============================================================
# ACE Credit Assignment Configuration
# ============================================================
ENABLE_CREDIT_TRACKING=false
NODE_QUALITY_THRESHOLD=-0.3

# ============================================================
# Knowledge Curator Configuration
# ============================================================
ENABLE_CURATOR=false
CURATOR_INTERVAL=10
CURATOR_PRUNE_DAYS=30
CURATOR_HARMFUL_THRESHOLD=2

# ============================================================
# Hybrid Search Configuration
# ============================================================
SEARCH_METHOD=hybrid
HYBRID_ALPHA=0.8

# ============================================================
# RAG Auto-Indexing Configuration
# ============================================================
ENABLE_RAG_AUTO_INDEX=false
RAG_FINE_GRAINED=false
RAG_RATE_LIMIT_DELAY_MS=100

# ============================================================
# Smart RAG Decision Configuration
# ============================================================
ENABLE_SMART_RAG=false
SMART_RAG_HIGH_THRESHOLD=0.50


SMART_RAG_TOP_K=3
SMART_RAG_LLM_JUDGE=true

# ============================================================
# Procedural Memory Configuration
# ============================================================
ENABLE_PROCEDURAL_MEMORY=false
PROCEDURAL_RETRIEVE_LIMIT=3
PROCEDURAL_SIMILARITY_THRESHOLD=0.5
PROCEDURAL_INJECT_GUIDANCE=true

# Disable Deep Think (deprecated - replaced by plan agent)
ENABLE_DEEP_THINK=false

DEBUG_RAG=false
ENABLE_SUB_AGENTS=true
FULL_PROMPT_DEBUG=false

# ============================================================
# v2 Multi-Agent Architecture
# ============================================================
# Hook System (context compression, tool output truncation, auto-continuation)
ENABLE_HOOKS=true
CONTEXT_COMPRESSION_THRESHOLD=0.80
TOOL_OUTPUT_MAX_CHARS=50000

# Background Agent System
BACKGROUND_MAX_WORKERS=3
BACKGROUND_MAX_ITERATIONS=15
BACKGROUND_RESULT_MAX_TOKENS=2000

# ============================================================
# SubAgent Debug Configuration
# ============================================================
# Enable detailed SubAgent debug logging (color-coded, verbose)
# Shows: parsing details, error checks, stall detection, tool calls
# Default: false
DEBUG_SUBAGENT=false

# Enable Context Flow monitoring (agent communication tracking)
# Shows: SharedContext updates, agent interactions, efficiency metrics
# Default: false
DEBUG_CONTEXT_FLOW=false

# ============================================================
# Tool Description System (OpenCode Integration)
# ============================================================
# Enable detailed tool descriptions from .txt files
# Default: true
ENABLE_TOOL_DESCRIPTIONS=true

# Limit Full Prompt Debug output messages
FULL_PROMPT_DEBUG_LIMIT_ENABLED=true
FULL_PROMPT_DEBUG_LIMIT_COUNT=5

# Limit lines per message in Full Prompt Debug
FULL_PROMPT_DEBUG_LINE_LIMIT_ENABLED=true
FULL_PROMPT_DEBUG_LINE_LIMIT_COUNT=20

# ============================================================
# Git Version Control
# ============================================================
# Automatically run git init (if needed) + git add + commit
# after every write_file / replace_in_file operation
# Default: true
# Enabled: write_file / replace_in_file / replace_lines auto git add+commit into
# the active IP's own .git (per-IP repos created by /new-ip). The PROJECT_ROOT
# escape guard keeps it from committing into the outer/source repo. Perforce is
# driven separately/manually by the user, so this is git-only by design.
GIT_VERSION_CONTROL_ENABLE=true
#GIT_VERSION_CONTROL_ENABLE=false

# Commit message mode for git version control
# simple  : "auto: write src/main.py [2026-03-26 14:32:01]"
# summary : above + LLM Thought 요약 앞에 추가
# Default: simple
# GIT_COMMIT_MSG_MODE=summary
GIT_COMMIT_MSG_MODE=simple

# Model used to generate git commit summaries (GIT_COMMIT_MSG_MODE=summary)
# Defaults to LLM_MODEL_NAME (same API/key as main LLM — no separate auth needed)
# GIT_COMMIT_SUMMARY_MODEL=openrouter/qwen/qwen-2.5-7b-instruct

# Temperature for commit summary LLM call (lower = more deterministic)
# Default: 0.3
GIT_COMMIT_SUMMARY_TEMPERATURE=0.3

# ============================================================
# SSL Configuration
# ============================================================
# Set to false for corporate networks with SSL inspection proxy
SSL_VERIFY=false

# ============================================================
# Custom Pricing Override
# ============================================================
# When true, all GLM models use flat pricing: input=$1/1M, cache=$0/1M, output=$1/1M
CUSTOM_PRICE=false

# ============================================================
# cursor-agent Backend (optional — replaces direct LLM API calls)
# ============================================================
# Set to true to route all LLM calls through the cursor-agent CLI
# instead of making HTTP requests to LLM_BASE_URL.
# Default: false
# CURSOR_AGENT_ENABLE: cursor-agent를 LLM 백엔드로 사용 (todo tracking 불가)
# false = 일반 LLM이 오케스트레이터 (권장)
#CURSOR_AGENT_ENABLE=true
CURSOR_AGENT_ENABLE=false

CURSOR_AGENT_MODEL=auto

# yolo=true: cursor_agent 도구 호출 시 파일 수정/쉘 실행 자동 허용
CURSOR_AGENT_YOLO=true

CURSOR_AGENT_MODE=
CURSOR_AGENT_WORKSPACE=

# CURSOR_AGENT_ACTIVE_MODE: 일반 LLM이 실행을 cursor_agent 도구로 자동 위임
# true  = LLM은 todo/오케스트레이션만, 파일·코드·쉘은 cursor_agent가 처리
# false = cursor_agent 도구는 있지만 LLM이 직접 결정
#CURSOR_AGENT_ACTIVE_MODE=true
CURSOR_AGENT_ACTIVE_MODE=false

# Permission flags — destructive shell command control
# Toggle at runtime with: /permission rm on|off  /permission mv on|off
ALLOW_RM=true
ALLOW_MV=true
ALLOW_DOCKER=true
# Auto-chmod u+w before write_file / replace_in_file / replace_lines on permission error
AUTO_CHMOD_WRITE=true


# Tool data limits (sent to LLM context)
TOOL_READ_MAX_LINES=3000
TOOL_FIND_MAX_RESULTS=1000
TOOL_GREP_MAX_FILES=50
TOOL_GREP_MAX_MATCHES=200
TOOL_LIST_MAX_ENTRIES=1000

# Display limits (shown in terminal — does NOT affect LLM context)
DISPLAY_READ_MAX_LINES=30
DISPLAY_FIND_MAX_RESULTS=20
DISPLAY_GREP_MAX_LINES=15
DISPLAY_LIST_MAX_ENTRIES=30
DISPLAY_RESULT_MAX_CHARS=2000

# Atlas web UI: how much of each tool_result obs to send over WebSocket
# to the browser. Browser-display only — does NOT affect LLM context.
# Bigger = user sees more of long reads/greps without "[truncated]";
# costs nothing in LLM tokens. The frontend caps render height anyway
# and adds horizontal scroll on overflow.
WS_TOOL_RESULT_MAX_CHARS=32000

# sim_debug workspace — SystemVerilog elaboration backend.
# pyslang   = Python bindings to slang. Default. Pure Python, no
#             subprocess, fastest startup. `pip install pyslang`.
# verilator = `verilator --json-only` subprocess. Mature, robust, but
#             slower (process spawn + JSON parse). `brew install verilator`.
# slang     = `slang --ast-json` CLI subprocess. Most accurate AST.
#             Requires building slang from source.
SIM_DEBUG_ELAB_BACKEND=dual

# ============================================================
# rtl-gen blocker QA card auto-skip
# ============================================================
# 1 = rtl-gen preflight writes rtl_blocked.json to disk (so
#     /resolve-rtl-blockers <ip> still works on demand) but does NOT
#     auto-promote the blockers into 8+ pending SSOT QA cards mid-flight.
# 0 = legacy behaviour — every rtl-gen blocker shows up as a QA card
#     the moment it lands, which spams chat when SSOT has many gaps.
# Default ON so the pipeline runs end-to-end without QA interruptions;
# ssot-gen remains the only stage that surfaces interactive Q&A.
ATLAS_RTL_BLOCKER_AUTO_SKIP=1
# Keep single-worker as the default local execution mode. Set this to 0 only
# when enabling the orchestrator profile above.
# ATLAS_SINGLE_MAIN_LOOP=0
