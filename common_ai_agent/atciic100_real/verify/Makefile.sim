# Generated for atciic100_real
PY ?= python3
HERE := $(dir $(realpath $(firstword $(MAKEFILE_LIST))))
IP_ROOT := $(realpath $(HERE)/..)

.PHONY: fl_only cl_only fl_cl_rtl

fl_only:
	$(PY) $(HERE)/cocotb_harness.py
	@echo "[Makefile.sim] fl_only OK"

cl_only:
	@if [ -f "$(IP_ROOT)/model/cycle_model.py" ]; then \
		$(PY) $(IP_ROOT)/model/cycle_model.py ; \
		echo "[Makefile.sim] cl_only OK" ; \
	else \
		echo "[Makefile.sim] cl_only SKIPPED (no cycle_model.py)" ; \
	fi

fl_cl_rtl:
	@echo "[Makefile.sim] fl_cl_rtl: cocotb harness ready, DUT runner not yet wired"
	$(PY) $(HERE)/cocotb_harness.py
