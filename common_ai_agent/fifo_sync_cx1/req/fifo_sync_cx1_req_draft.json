  "structural_contracts": {
    "ip": "fifo_sync_cx1",
    "contracts": [
      {
        "id": "SC_FIFO_PORTS",
        "obligations": ["OBL_FIFO_WRITE_001", "OBL_FIFO_READ_001", "OBL_FIFO_FLAGS_001", "OBL_FIFO_RESET_001", "OBL_FIFO_LINT_001"],
        "signals": [
          {"name": "clk",     "dir": "input",  "width": 1, "timing": {"kind": "clock"}},
          {"name": "rst_n",   "dir": "input",  "width": 1, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "wr_en",   "dir": "input",  "width": 1, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "wr_data", "dir": "input",  "width": 8, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "rd_en",   "dir": "input",  "width": 1, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "rd_data", "dir": "output", "width": 8, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "full",    "dir": "output", "width": 1, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "empty",   "dir": "output", "width": 1, "timing": {"kind": "sync", "clock_domain": "main"}}
        ],
        "clock_domains": [
          {"id": "main", "clock_signal": "clk"}
        ],
        "reset_domains": [
          {"id": "sync_rst", "reset_signal": "rst_n", "clock_domain": "main"}
        ],
        "interfaces": [
          {"id": "fifo_io", "signals": ["wr_en", "wr_data", "rd_en", "rd_data", "full", "empty"], "clock_domain": "main"}
        ]
      }
    ]
  },
  "behavioral_contracts": {
    "ip": "fifo_sync_cx1",
    "contracts": [
      {
        "id": "BC_FIFO_WRITE",
        "obligation_refs": ["OBL_FIFO_WRITE_001"],
        "ssot_section": "function_model",
        "transactions": [
          {
            "id": "FM_WRITE",
            "preconditions": ["rst_n == 1", "wr_en == 1", "full == 0"],
            "outputs": [{"name": "full", "expr": "(count + 1) == 8"}, {"name": "empty", "expr": "0"}],
            "state_updates": [{"name": "count", "expr": "count + 1"}, {"name": "wr_ptr", "expr": "(wr_ptr + 1) % 8"}]
          }
        ],
        "latency": {"write_update": "1 clock cycle: count and wr_ptr update one rising clk after wr_en sampled"},
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/fifo_sync_cx1.sv"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_fifo_sync_cx1.py"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "count increments on each accepted write"}
        ]
      },
      {
        "id": "BC_FIFO_READ",
        "obligation_refs": ["OBL_FIFO_READ_001"],
        "ssot_section": "function_model",
        "transactions": [
          {
            "id": "FM_READ",
            "preconditions": ["rst_n == 1", "rd_en == 1", "empty == 0"],
            "outputs": [{"name": "rd_data", "expr": "head_data"}, {"name": "empty", "expr": "(count - 1) == 0"}],
            "state_updates": [{"name": "count", "expr": "count - 1"}, {"name": "rd_ptr", "expr": "(rd_ptr + 1) % 8"}]
          }
        ],
        "latency": {"read_update": "1 clock cycle: count and rd_ptr update one rising clk after rd_en sampled"},
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/fifo_sync_cx1.sv"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_fifo_sync_cx1.py"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "rd_data matches written data; count decrements"}
        ]
      },
      {
        "id": "BC_FIFO_FLAGS",
        "obligation_refs": ["OBL_FIFO_FLAGS_001"],
        "ssot_section": "function_model",
        "cycle_model_waiver": "flags are combinational state functions (count==8, count==0); no additional cycle model beyond write/read BCs",
        "timing": "full and empty update within the same clock cycle as count; combinational decode of registered count",
        "transactions": [
          {
            "id": "FM_FLAGS",
            "preconditions": ["rst_n == 1"],
            "outputs": [{"name": "full", "expr": "count == 8"}, {"name": "empty", "expr": "count == 0"}],
            "state_updates": []
          }
        ],
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/fifo_sync_cx1.sv", "timing": "combinational decode of registered count"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "full asserts at count==8; empty asserts at count==0"}
        ]
      },
      {
        "id": "BC_FIFO_RESET",
        "obligation_refs": ["OBL_FIFO_RESET_001"],
        "ssot_section": "cycle_model",
        "transactions": [
          {
            "id": "TR_RESET",
            "preconditions": ["rst_n == 0"],
            "outputs": [{"name": "full", "expr": "0"}, {"name": "empty", "expr": "1"}],
            "state_updates": [{"name": "count", "expr": "0"}, {"name": "wr_ptr", "expr": "0"}, {"name": "rd_ptr", "expr": "0"}]
          }
        ],
        "reset": "synchronous active-low; count/ptrs clear to 0 on rising clk when rst_n==0",
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/fifo_sync_cx1.sv"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "empty==1 and full==0 after reset"}
        ]
      },
      {
        "id": "BC_FIFO_LINT",
        "obligation_refs": ["OBL_FIFO_LINT_001"],
        "ssot_section": "coding_rules",
        "cycle_model_waiver": "lint-only obligation; no cycle model required — latch-free structure is a static synthesis property",
        "invariants": [
          "No inferred latches in fifo_sync_cx1 RTL",
          "All state (count, wr_ptr, rd_ptr, fifo_memory) is registered"
        ],
        "stage_contracts": [
          {"stage": "lint", "artifact": "lint/dut_lint.json", "pass_condition": "no latch findings"}
        ]
      }
    ]
  },
