        ]
      },
      {
        "name": "MPIDR_EL1", "encoding": "S3_0_C0_C0_5", "access": "RO", "reset": "0x80000xxx",
        "desc": "Multiprocessor Affinity Register — core/cluster identification.",
        "fields": [
          { "name": "U",    "msb": 30, "lsb": 30, "desc": "1 = uniprocessor (illustrative)" },
          { "name": "MT",   "msb": 24, "lsb": 24, "reset": "0", "desc": "Multithreading (0 for A53)" },
          { "name": "Aff2", "msb": 23, "lsb": 16, "desc": "Affinity level 2 (cluster)" },
          { "name": "Aff1", "msb": 15, "lsb": 8,  "desc": "Affinity level 1" },
          { "name": "Aff0", "msb": 7,  "lsb": 0,  "desc": "Affinity level 0 (core id)" }
        ]
      },
      {
        "name": "SCTLR_EL1", "encoding": "S3_0_C1_C0_0", "access": "RW", "reset": "0x00C50838",
        "desc": "System Control Register (EL1) — MMU, cache and alignment controls.",
        "fields": [
          { "name": "EE",  "msb": 25, "lsb": 25, "desc": "Exception endianness at EL1" },
