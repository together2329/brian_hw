  "registers": {
    "note": "ARMv8-A system registers are accessed with MRS/MSR via op0/op1/CRn/CRm/op2 encodings (not memory-mapped offsets). Subset shown is representative; reset values are illustrative except where architecturally fixed.",
    "register_list": [
      {
        "name": "MIDR_EL1", "encoding": "S3_0_C0_C0_0", "access": "RO", "reset": "0x410FD03x",
        "desc": "Main ID Register — identifies the implementer and part.",
        "fields": [
          { "name": "Implementer", "msb": 31, "lsb": 24, "reset": "0x41", "desc": "0x41 = ARM Limited (fixed)" },
          { "name": "Variant",     "msb": 23, "lsb": 20, "desc": "rNpM variant (illustrative)" },
          { "name": "Architecture","msb": 19, "lsb": 16, "reset": "0xF",  "desc": "0xF = defined by CPUID scheme (ARMv8)" },
          { "name": "PartNum",     "msb": 15, "lsb": 4,  "reset": "0xD03","desc": "0xD03 = Cortex-A53 (fixed)" },
          { "name": "Revision",    "msb": 3,  "lsb": 0,  "desc": "rNpM revision (illustrative)" }
        ]
      },
      {
        "name": "MPIDR_EL1", "encoding": "S3_0_C0_C0_5", "access": "RO", "reset": "0x80000xxx",
        "desc": "Multiprocessor Affinity Register — core/cluster identification.",
        "fields": [
          { "name": "U",    "msb": 30, "lsb": 30, "desc": "1 = uniprocessor (illustrative)" },
          { "name": "MT",   "msb": 24, "lsb": 24, "reset": "0", "desc": "Multithreading (0 for A53)" },
          { "name": "Aff2", "msb": 23, "lsb": 16, "desc": "Affinity level 2 (cluster)" },
          { "name": "Aff1", "msb": 15, "lsb": 8,  "desc": "Affinity level 1" },
          { "name": "Aff0", "msb": 7,  "lsb": 0,  "desc": "Affinity level 0 (core id)" }
        ]
      },
      {
        "name": "SCTLR_EL1", "encoding": "S3_0_C1_C0_0", "access": "RW", "reset": "0x00C50838",
        "desc": "System Control Register (EL1) — MMU, cache and alignment controls.",
        "fields": [
          { "name": "EE",  "msb": 25, "lsb": 25, "desc": "Exception endianness at EL1" },
          { "name": "WXN", "msb": 19, "lsb": 19, "desc": "Writeable implies execute-never" },
          { "name": "I",   "msb": 12, "lsb": 12, "reset": "0", "desc": "Instruction cache enable" },
          { "name": "SA0", "msb": 4,  "lsb": 4,  "desc": "EL0 stack alignment check" },
          { "name": "SA",  "msb": 3,  "lsb": 3,  "desc": "Stack alignment check" },
          { "name": "C",   "msb": 2,  "lsb": 2,  "reset": "0", "desc": "Data cache enable" },
          { "name": "A",   "msb": 1,  "lsb": 1,  "desc": "Alignment check enable" },
          { "name": "M",   "msb": 0,  "lsb": 0,  "reset": "0", "desc": "MMU enable" }
        ]
      },
      {
        "name": "CPACR_EL1", "encoding": "S3_0_C1_C0_2", "access": "RW", "reset": "0x00000000",
        "desc": "Architectural Feature Access Control — FP/SIMD and trace trap control.",
        "fields": [
          { "name": "TTA",  "msb": 28, "lsb": 28, "desc": "Trap trace register accesses" },
          { "name": "FPEN", "msb": 21, "lsb": 20, "desc": "FP/SIMD trap control (0b11 = no trap)" }
        ]
      },
      { "name": "TTBR0_EL1",      "encoding": "S3_0_C2_C0_0", "access": "RW", "desc": "Translation Table Base Register 0 (EL1)." },
      { "name": "TTBR1_EL1",      "encoding": "S3_0_C2_C0_1", "access": "RW", "desc": "Translation Table Base Register 1 (EL1)." },
      { "name": "TCR_EL1",        "encoding": "S3_0_C2_C0_2", "access": "RW", "desc": "Translation Control Register (EL1)." },
      { "name": "ESR_EL1",        "encoding": "S3_0_C5_C2_0", "access": "RW", "desc": "Exception Syndrome Register (EL1)." },
      { "name": "FAR_EL1",        "encoding": "S3_0_C6_C0_0", "access": "RW", "desc": "Fault Address Register (EL1)." },
      { "name": "VBAR_EL1",       "encoding": "S3_0_C12_C0_0","access": "RW", "desc": "Vector Base Address Register (EL1)." },
      { "name": "CTR_EL0",        "encoding": "S3_3_C0_C0_1", "access": "RO", "desc": "Cache Type Register." },
      { "name": "ID_AA64PFR0_EL1","encoding": "S3_0_C0_C4_0", "access": "RO", "desc": "AArch64 Processor Feature Register 0 (FP/SIMD/EL support)." }
    ]
  },
  "timing": {
    "title": "ACE/AXI read burst — 2-beat (illustrative AMBA 4)",
    "note": "AR address handshake (ARVALID·ARREADY), then R data channel (RVALID·RREADY), RLAST on the final beat.",
    "signals": [
      { "name": "ACLK",    "wave": "pppppppp" },
      { "name": "ARVALID", "wave": "01.0...." },
      { "name": "ARREADY", "wave": "0.10...." },
      { "name": "ARADDR",  "wave": "x=.x....", "data": ["0x80000000"] },
      { "name": "RVALID",  "wave": "0...1.0." },
      { "name": "RREADY",  "wave": "0...1.0." },
      { "name": "RDATA",   "wave": "x...==x.", "data": ["0xCD00", "0xCD04"] },
      { "name": "RLAST",   "wave": "0....1.0" }
    ]
  }
