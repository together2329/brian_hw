  "structural_contracts": {
    "ip": "watchdog_cx1",
    "contracts": [
      {
        "id": "SC_WDT_PORTS",
        "obligations": ["OBL_WDT_TICK_001", "OBL_WDT_TIMEOUT_001", "OBL_WDT_IDLE_001", "OBL_WDT_KICK_001", "OBL_WDT_LINT_001"],
        "signals": [
          {"name": "PCLK",         "dir": "input",  "width": 1,  "timing": {"kind": "clock"}},
          {"name": "PRESETn",       "dir": "input",  "width": 1,  "timing": {"kind": "reset"}},
          {"name": "PADDR",         "dir": "input",  "width": 4,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PSEL",          "dir": "input",  "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PENABLE",       "dir": "input",  "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PWRITE",        "dir": "input",  "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PWDATA",        "dir": "input",  "width": 32, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PRDATA",        "dir": "output", "width": 32, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PREADY",        "dir": "output", "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PSLVERR",       "dir": "output", "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "timeout_pulse", "dir": "output", "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}}
        ],
        "clock_domains": [
          {"id": "main", "clock_signal": "PCLK"}
        ],
        "reset_domains": [
          {"id": "async_rst", "reset_signal": "PRESETn", "clock_domain": "main"}
        ],
        "interfaces": [
          {"id": "apb_iface", "signals": ["PADDR","PSEL","PENABLE","PWRITE","PWDATA","PRDATA","PREADY","PSLVERR"], "clock_domain": "main"},
          {"id": "wdt_iface", "signals": ["timeout_pulse"], "clock_domain": "main"}
        ]
      }
    ]
  },
  "behavioral_contracts": {
    "ip": "watchdog_cx1",
    "contracts": [
      {
        "id": "BC_WDT_TICK",
        "obligation_refs": ["OBL_WDT_TICK_001"],
        "ssot_section": "function_model",
        "timing": "count_q registered on rising PCLK; decrements 1 cycle after sampling enable",
        "latency": {
          "count_decrement": "1 clock cycle: count_q updates one rising PCLK after enable sampled"
        },
        "ordering": "KICK write has priority over tick in the same cycle",
        "transactions": [
          {
            "id": "TR_TICK",
            "preconditions": ["PRESETn == 1", "enable_q == 1", "not (PSEL==1 and PENABLE==1 and PWRITE==1 and PADDR==4)"],
            "outputs": [{"name": "timeout_pulse", "expr": "1 if count_q == 1 else 0"}],
            "state_updates": [{"name": "count_q", "expr": "period_q if count_q == 1 else (count_q - 1) & 0xFF"}]
          }
        ],
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/watchdog_cx1.sv", "timing": "synchronous PCLK, 1-cycle latency"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_watchdog_cx1.py", "timing": "stimulus applied one cycle before expected result"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "count_q decrements match FL expected", "latency": "1 clock cycle per decrement"}
        ]
      },
      {
        "id": "BC_WDT_TIMEOUT",
        "obligation_refs": ["OBL_WDT_TIMEOUT_001"],
        "ssot_section": "function_model",
        "timing": "timeout_pulse asserted for exactly 1 PCLK cycle when count_q==1; count_q reloads on same cycle",
        "latency": {
          "timeout_pulse_width": "exactly 1 clock cycle"
        },
        "ordering": "timeout fires when count_q reaches 1 (one tick before zero)",
        "transactions": [
          {
            "id": "TR_TIMEOUT",
            "preconditions": ["PRESETn == 1", "enable_q == 1", "count_q == 1"],
            "outputs": [{"name": "timeout_pulse", "expr": "1"}],
            "state_updates": [{"name": "count_q", "expr": "period_q"}]
          }
        ],
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/watchdog_cx1.sv", "timing": "timeout_pulse is registered output, 1-cycle wide"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_watchdog_cx1.py", "timing": "verify pulse width=1 cycle and auto-reload"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "timeout_pulse==1 for exactly 1 cycle when count_q==1", "latency": "1 cycle pulse"}
        ]
      },
      {
        "id": "BC_WDT_IDLE",
        "obligation_refs": ["OBL_WDT_IDLE_001"],
        "ssot_section": "function_model",
        "timing": "count_q holds its registered value when enable_q==0; no decrement cycle",
        "cycle_model_waiver": "frozen counter: no state change when enable_q==0; cycle semantics covered by BC_WDT_TICK",
        "transactions": [
          {
            "id": "TR_IDLE",
            "preconditions": ["PRESETn == 1", "enable_q == 0"],
            "outputs": [{"name": "timeout_pulse", "expr": "0"}],
            "state_updates": [{"name": "count_q", "expr": "count_q"}]
          }
        ],
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/watchdog_cx1.sv", "timing": "no state change when enable_q==0"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_watchdog_cx1.py", "timing": "verify count_q stable across multiple cycles with enable==0"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "count_q unchanged and timeout_pulse==0 when disabled", "latency": "0 cycles of change"}
        ]
      },
      {
        "id": "BC_WDT_KICK",
        "obligation_refs": ["OBL_WDT_KICK_001"],
        "ssot_section": "function_model",
        "timing": "count_q reloads from period_q 1 cycle after APB KICK access-phase write",
        "latency": {
          "kick_to_reload": "1 clock cycle after KICK access-phase write"
        },
        "ordering": "KICK write takes priority over tick decrement in the same cycle",
        "transactions": [
          {
            "id": "TR_KICK",
            "preconditions": ["PRESETn == 1", "PSEL == 1", "PENABLE == 1", "PWRITE == 1", "PADDR == 4"],
            "outputs": [{"name": "timeout_pulse", "expr": "0"}],
            "state_updates": [{"name": "count_q", "expr": "period_q"}]
          }
        ],
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/watchdog_cx1.sv", "timing": "synchronous PCLK, 1-cycle latency"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_watchdog_cx1.py", "timing": "stimulus applied one cycle before expected result"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "count_q=period_q after KICK write", "latency": "1 clock cycle"}
        ]
      },
      {
        "id": "BC_WDT_LINT",
        "obligation_refs": ["OBL_WDT_LINT_001"],
        "ssot_section": "coding_rules",
        "timing": "count_q is a clocked register; no combinational loop or latch inference",
        "cycle_model_waiver": "lint-only obligation; functional cycle model covered by BC_WDT_TICK and BC_WDT_KICK",
        "invariants": [
          "No inferred latches in watchdog_cx1 RTL",
          "All registers are single-driver"
        ],
        "stage_contracts": [
          {"stage": "lint", "artifact": "lint/dut_lint.json", "pass_condition": "no latch findings", "timing": "registered outputs; no async path"}
        ]
      }
    ]
  },
