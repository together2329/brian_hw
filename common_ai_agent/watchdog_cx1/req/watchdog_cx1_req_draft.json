      "requirement_refs": ["REQ_WDT_FUNC_001"],
      "statement": "When CTRL.enable==0, count_q holds its value and timeout_pulse=0.",
      "contract_refs": ["C_WDT_IDLE"],
      "structural_contract_refs": ["SC_WDT_PORTS"],
      "behavioral_contract_refs": ["BC_WDT_IDLE"],
      "required_stages": ["rtl", "tb", "sim"],
