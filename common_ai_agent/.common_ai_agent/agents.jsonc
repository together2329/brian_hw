{
  // Common AI Agent Agent Configuration (OpenCode-Inspired)
  //
  // This file allows you to customize agents without code changes.
  // Supported features:
  // - Custom agents with specific tools and permissions
  // - Agent-specific LLM models (different models for different tasks)
  // - Wildcard permission patterns for bash commands
  //
  // Configuration is merged with native agents (explore, plan, execute, review, build)

  "agents": {
    // 네이티브 에이전트 (model은 환경변수로 제어)
    // SUBAGENT_LOW_MODEL  → explore, execute, review, task
    // SUBAGENT_HIGH_MODEL → plan
    // PRIMARY_MODEL       → primary
    "explore": { "temperature": 0.3 },
    "plan":    { "temperature": 0.2 },
    "execute": { "temperature": 0.3 },
    "review":  { "temperature": 0.1 },
    "task":    { "temperature": 0.2 },
    "primary": { "temperature": 0.3 },

    // Spec Q&A agent — handles PCIe/NVMe/UCIe spec questions in isolated context
    "spec-navigator": {
      "description": "Technical spec Q&A agent (PCIe/NVMe/UCIe). Answers questions using spec_search and spec_navigate.",
      "mode": "subagent",
      "temperature": 0.1,
      "tools": {
        "spec_search": true,
        "spec_navigate": true,
        "read_lines": true,
        "grep_file": true,
        "write_file": false,
        "replace_in_file": false,
        "run_command": false
      },
      "permission": {
        "edit": "deny",
        "bash": { "*": "deny" }
      }
    },

    // Example: Custom Verilog specialist agent
    "verilog-expert": {
      "description": "Specialized agent for Verilog/SystemVerilog analysis and implementation",
      "mode": "subagent",
      "model": "openrouter/anthropic/claude-3.5-sonnet",
      "temperature": 0.2,
      "prompt": "You are a Verilog/SystemVerilog expert. Focus on RTL design, timing analysis, FSM implementation, and synthesis optimization. Always consider clock domain crossings and reset handling.",
      "tools": {
        "read_file": true,
        "read_lines": true,
        "grep_file": true,
        "write_file": true,
        "replace_in_file": true,
        "run_command": true,
        "analyze_verilog_module": true,
        "find_signal_usage": true
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "iverilog*": "allow",
          "vvp*": "allow",
          "yosys*": "allow",
          "make*": "allow",
          "rm -rf*": "deny",
          "*": "ask"
        }
      }
    },

    // Example: Secure code review agent (read-only)
    "security-reviewer": {
      "description": "Security-focused code review agent. Read-only access.",
      "mode": "subagent",
      "model": "openrouter/anthropic/claude-3-opus",
      "temperature": 0.1,
      "prompt": "You are a security expert. Analyze code for vulnerabilities: SQL injection, XSS, buffer overflows, authentication issues, insecure dependencies. Be thorough and precise.",
      "tools": {
        "read_file": true,
        "read_lines": true,
        "grep_file": true,
        "find_files": true,
        "write_file": false,
        "replace_in_file": false,
        "run_command": false
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "grep*": "allow",
          "rg*": "allow",
          "cat*": "allow",
          "*": "deny"
        }
      }
    },

    // Example: Fast summarizer using cheap model
    "summarizer": {
      "description": "Fast summarization using lightweight model",
      "mode": "subagent",
      "hidden": true,
      "model": "openrouter/google/gemini-flash-1.5-8b",
      "temperature": 0.3,
      "tools": {
        "read_file": true,
        "read_lines": true
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny"
        }
      }
    }
  },

  // Global default permissions (applied to new agents without explicit permission)
  "default_permission": {
    "edit": "allow",
    "bash": {
      "git*": "allow",
      "ls*": "allow",
      "cat*": "allow",
      "grep*": "allow",
      "find*": "allow",
      "make*": "ask",
      "rm -rf*": "deny",
      "*": "ask"
    },
    "webfetch": "allow",
    "external_directory": "ask"
  }
}
