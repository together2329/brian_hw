  "structural_contracts": {
    "ip": "uart_tx_lite_cx1",
    "contracts": [
      {
        "id": "SC_UART_PORTS",
        "obligations": ["OBL_UART_TX_001", "OBL_UART_BUSY_001", "OBL_UART_IDLE_001", "OBL_UART_DROP_001", "OBL_UART_LINT_001"],
        "signals": [
          {"name": "PCLK",    "dir": "input",  "width": 1,  "timing": {"kind": "clock"}},
          {"name": "PRESETn", "dir": "input",  "width": 1,  "timing": {"kind": "reset"}},
          {"name": "PADDR",   "dir": "input",  "width": 4,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PSEL",    "dir": "input",  "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PENABLE", "dir": "input",  "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PWRITE",  "dir": "input",  "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PWDATA",  "dir": "input",  "width": 32, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PRDATA",  "dir": "output", "width": 32, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PREADY",  "dir": "output", "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "PSLVERR", "dir": "output", "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "tx_out",  "dir": "output", "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "tx_busy", "dir": "output", "width": 1,  "timing": {"kind": "sync", "clock_domain": "main"}}
        ],
        "clock_domains": [
          {"id": "main", "clock_signal": "PCLK"}
        ],
        "reset_domains": [
          {"id": "async_rst", "reset_signal": "PRESETn", "clock_domain": "main"}
        ],
        "interfaces": [
          {"id": "apb_iface",  "signals": ["PADDR","PSEL","PENABLE","PWRITE","PWDATA","PRDATA","PREADY","PSLVERR"], "clock_domain": "main"},
          {"id": "uart_iface", "signals": ["tx_out","tx_busy"], "clock_domain": "main"}
        ]
      }
    ]
  },
  "behavioral_contracts": {
    "ip": "uart_tx_lite_cx1",
    "contracts": [
      {
        "id": "BC_UART_TX",
        "obligation_refs": ["OBL_UART_TX_001"],
        "ssot_section": "function_model",
        "timing": "tx_out registered on rising PCLK; each bit state held for BAUD_DIV cycles",
        "latency": {
          "frame_length": "10 * BAUD_DIV PCLK cycles: 1 start + 8 data + 1 stop"
        },
        "ordering": "start bit begins on cycle after TX_DATA APB write accepted",
        "transactions": [
          {
            "id": "TR_TX_BYTE",
            "preconditions": ["PRESETn == 1", "PSEL == 1", "PENABLE == 1", "PWRITE == 1", "PADDR == 0", "tx_busy_q == 0"],
            "outputs": [{"name": "tx_busy", "expr": "1"}, {"name": "tx_out", "expr": "1"}],
            "state_updates": [{"name": "tx_busy_q", "expr": "1"}, {"name": "shift_reg", "expr": "PWDATA & 0xFF"}, {"name": "tx_state", "expr": "1"}]
          }
        ],
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/uart_tx_lite_cx1.sv", "timing": "baud counter gates bit transitions; 8N1 frame"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_uart_tx_lite_cx1.py", "timing": "observe tx_out for full 10*BAUD_DIV cycles"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "8N1 frame shape matches FL expected", "latency": "10*BAUD_DIV cycles per frame"}
        ]
      },
      {
        "id": "BC_UART_BUSY",
        "obligation_refs": ["OBL_UART_BUSY_001"],
        "ssot_section": "function_model",
        "timing": "tx_busy registered on rising PCLK; set on TX_DATA write, cleared after stop bit completes",
        "latency": {
          "busy_duration": "10 * BAUD_DIV PCLK cycles from TX_DATA write to tx_busy deassertion"
        },
        "ordering": "tx_busy clears on the cycle after the stop bit baud period ends",
        "transactions": [
          {
            "id": "TR_BUSY",
            "preconditions": ["PRESETn == 1", "tx_busy_q == 1"],
            "outputs": [{"name": "tx_busy", "expr": "1"}],
            "state_updates": [{"name": "tx_busy_q", "expr": "1"}]
          }
        ],
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/uart_tx_lite_cx1.sv", "timing": "tx_busy set on TX_DATA write; cleared after stop bit"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_uart_tx_lite_cx1.py", "timing": "verify tx_busy high through frame, low after stop"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "tx_busy=1 during frame, tx_busy=0 after stop bit", "latency": "10*BAUD_DIV cycles"}
        ]
      },
      {
        "id": "BC_UART_IDLE",
        "obligation_refs": ["OBL_UART_IDLE_001"],
        "ssot_section": "function_model",
        "timing": "tx_out holds 1 (mark/idle) and tx_busy holds 0 when no transmission active",
        "cycle_model_waiver": "idle is steady-state; cycle semantics covered by BC_UART_TX and BC_UART_BUSY",
        "transactions": [
          {
            "id": "TR_IDLE",
            "preconditions": ["PRESETn == 1", "tx_busy_q == 0"],
            "outputs": [{"name": "tx_out", "expr": "1"}, {"name": "tx_busy", "expr": "0"}],
            "state_updates": [{"name": "tx_busy_q", "expr": "0"}]
          }
        ],
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/uart_tx_lite_cx1.sv", "timing": "tx_out=1 static when no frame active"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_uart_tx_lite_cx1.py", "timing": "verify idle state before and after frames"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "tx_out=1 and tx_busy=0 when idle", "latency": "0 cycles of change"}
        ]
      },
      {
        "id": "BC_UART_DROP",
        "obligation_refs": ["OBL_UART_DROP_001"],
        "ssot_section": "function_model",
        "timing": "ignored write completes APB handshake in 1 cycle but does not change shift register or FSM state",
        "latency": {
          "drop_response": "1 cycle APB PREADY; no frame effect"
        },
        "ordering": "busy check occurs before loading shift register; write ignored when tx_busy==1",
        "transactions": [
          {
            "id": "TR_DROP",
            "preconditions": ["PRESETn == 1", "PSEL == 1", "PENABLE == 1", "PWRITE == 1", "PADDR == 0", "tx_busy_q == 1"],
            "outputs": [{"name": "tx_busy", "expr": "1"}],
            "state_updates": [{"name": "tx_busy_q", "expr": "1"}]
          }
        ],
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/uart_tx_lite_cx1.sv", "timing": "write while busy completes APB but does not reload shift_reg"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_uart_tx_lite_cx1.py", "timing": "verify second write mid-frame does not corrupt output"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "write while busy silently ignored; frame unaffected", "latency": "1 cycle APB handshake only"}
        ]
      },
      {
        "id": "BC_UART_LINT",
        "obligation_refs": ["OBL_UART_LINT_001"],
        "ssot_section": "coding_rules",
        "timing": "all signals are registered; no combinational loop or latch inference",
        "cycle_model_waiver": "lint-only obligation; functional cycle model covered by BC_UART_TX",
        "invariants": [
          "No inferred latches in uart_tx_lite_cx1 RTL",
          "All registers are single-driver"
        ],
        "stage_contracts": [
          {"stage": "lint", "artifact": "lint/dut_lint.json", "pass_condition": "no latch findings", "timing": "registered outputs; no async path"}
        ]
      }
    ]
  },
