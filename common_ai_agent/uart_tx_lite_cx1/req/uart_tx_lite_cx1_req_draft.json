      "requirement_refs": ["REQ_UART_FUNC_001"],
      "statement": "When tx_busy=0 and no write, tx_out=1 (idle/mark) and tx_busy=0.",
      "contract_refs": ["C_UART_IDLE"],
      "structural_contract_refs": ["SC_UART_PORTS"],
      "behavioral_contract_refs": ["BC_UART_IDLE"],
      "required_stages": ["rtl", "tb", "sim"],
