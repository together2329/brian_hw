  "structural_contracts": {
    "ip": "counter8_cx1",
    "contracts": [
      {
        "id": "SC_CNT8_PORTS",
        "obligations": ["OBL_CNT8_COUNT_001", "OBL_CNT8_RESET_001", "OBL_CNT8_HOLD_001", "OBL_CNT8_LINT_001"],
        "signals": [
          {"name": "clk",   "dir": "input",  "width": 1, "timing": {"kind": "clock"}},
          {"name": "rst_n", "dir": "input",  "width": 1, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "en",    "dir": "input",  "width": 1, "timing": {"kind": "sync", "clock_domain": "main"}},
          {"name": "count", "dir": "output", "width": 8, "timing": {"kind": "sync", "clock_domain": "main"}}
        ],
        "clock_domains": [
          {"id": "main", "clock_signal": "clk"}
        ],
        "reset_domains": [
          {"id": "sync_rst", "reset_signal": "rst_n", "clock_domain": "main"}
        ],
        "interfaces": [
          {"id": "ctrl_iface", "signals": ["en", "count"], "clock_domain": "main"}
        ]
      }
    ]
  },
  "behavioral_contracts": {
    "ip": "counter8_cx1",
    "contracts": [
      {
        "id": "BC_CNT8_COUNT",
        "obligation_refs": ["OBL_CNT8_COUNT_001"],
        "ssot_section": "function_model",
        "transactions": [
          {
            "id": "TR_COUNT",
            "preconditions": ["rst_n == 1", "en == 1"],
            "outputs": [{"name": "count", "expr": "(count_reg + 1) & 0xFF"}],
            "state_updates": [{"name": "count_reg", "expr": "(count_reg + 1) & 0xFF"}]
          }
        ],
        "latency": {"count_update": "1 clock cycle: count updates one rising clk after en sampled"},
        "timing": "count registered on rising clk edge; reset synchronous active-low",
        "ordering": "reset (rst_n==0) takes priority over enable (en==1) in same cycle",
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/counter8_cx1.sv", "timing": "synchronous reset, 1-cycle latency"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_counter8_cx1.py", "timing": "stimulus applied one cycle before expected count"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "count increments match FL expected", "latency": "1 clock cycle per increment"}
        ]
      },
      {
        "id": "BC_CNT8_RESET",
        "obligation_refs": ["OBL_CNT8_RESET_001"],
        "ssot_section": "function_model",
        "transactions": [
          {
            "id": "TR_RESET",
            "preconditions": ["rst_n == 0"],
            "outputs": [{"name": "count", "expr": "0"}],
            "state_updates": [{"name": "count_reg", "expr": "0"}]
          }
        ],
        "reset": "synchronous active-low; count clears to 0 on rising clk when rst_n==0",
        "latency": {"reset_clear": "1 clock cycle: count==0 one rising clk after rst_n asserts"},
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/counter8_cx1.sv", "reset": "synchronous active-low"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_counter8_cx1.py", "reset": "drive rst_n=0 one cycle, check count==0 next cycle"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "count==0 one cycle after rst_n asserts", "latency": "1 cycle reset-to-clear"}
        ]
      },
      {
        "id": "BC_CNT8_HOLD",
        "obligation_refs": ["OBL_CNT8_HOLD_001"],
        "ssot_section": "function_model",
        "transactions": [
          {
            "id": "TR_HOLD",
            "preconditions": ["rst_n == 1", "en == 0"],
            "outputs": [{"name": "count", "expr": "count_reg"}],
            "state_updates": [{"name": "count_reg", "expr": "count_reg"}]
          }
        ],
        "timing": "count holds its registered value when en==0; no increment cycle",
        "ordering": "hold is the default state when en==0 and rst_n==1",
        "stage_contracts": [
          {"stage": "rtl",  "artifact": "rtl/counter8_cx1.sv", "timing": "no state change when en==0"},
          {"stage": "tb",   "artifact": "tb/cocotb/test_counter8_cx1.py", "timing": "verify count stable across multiple cycles with en==0"},
          {"stage": "sim",  "artifact": "sim/scoreboard_events.jsonl", "pass_condition": "count unchanged when en==0", "latency": "0 cycles of change"}
        ]
      },
      {
        "id": "BC_CNT8_LINT",
        "obligation_refs": ["OBL_CNT8_LINT_001"],
        "ssot_section": "coding_rules",
        "invariants": [
          "No inferred latches in counter8_cx1 RTL",
          "count is registered; single driver"
        ],
        "timing": "count is a clocked register; no combinational loop or latch inference",
        "cycle_model_waiver": "lint-only obligation; functional cycle model covered by BC_CNT8_COUNT and BC_CNT8_RESET",
        "stage_contracts": [
          {"stage": "lint", "artifact": "lint/dut_lint.json", "pass_condition": "no latch findings", "timing": "registered output; no async path"}
        ]
      }
    ]
  },
