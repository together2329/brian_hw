# Common AI Agent Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================================
# LLM Provider Configuration
# ============================================================
# Provider: openai (default) | azure | anthropic | openrouter | zai
# Default: openai
# LLM_PROVIDER=openai

# ============================================================
# Azure OpenAI Configuration (set LLM_PROVIDER=azure to activate)
# ============================================================
# Required when LLM_PROVIDER=azure:
# AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-api-key-here
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini-deploy
# Optional:
#   AZURE_OPENAI_API_VERSION — API version (default: 2025-04-01-preview)
#
# Recommended API versions:
#   2024-06-01            — GA, stable (default)
#   2024-10-21            — GA, Structured Outputs support
#   2025-04-01-preview    — Preview, latest models (GPT-4.1, GPT-5, Codex)
#
# When LLM_PROVIDER=azure, config.py auto-sets:
#   BASE_URL  = AZURE_OPENAI_ENDPOINT
#   API_KEY   = AZURE_OPENAI_API_KEY  (fallback: LLM_API_KEY)
#   MODEL_NAME= AZURE_OPENAI_DEPLOYMENT (fallback: LLM_MODEL_NAME)

# ============================================================
# Responses API Configuration
# ============================================================
# Set to true to use the OpenAI Responses API (/responses endpoint) instead of
# Chat Completions (/chat/completions). Required for gpt-5.x-codex models
# (both OpenAI and Azure).
#
# Responses API differences from Chat Completions:
#   - Uses `input` instead of `messages`
#   - Uses `instructions` instead of system message
#   - Uses `max_output_tokens` instead of `max_tokens`/`max_completion_tokens`
#   - Returns `output[].content[].text` instead of `choices[].message.content`
#   - Streaming uses typed events: response.output_text.delta, response.completed, etc.
#
# Note: OpenAI models with 'gpt'+'codex' in the name are auto-detected
# and routed to Responses API regardless of this setting.
# This flag is for Azure deployments or non-standard model names.
#
# Default: false (use Chat Completions)
# USE_RESPONSES_API=false

# ============================================================
# OpenRouter / Direct API Configuration
# ============================================================
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-openrouter-api-key-here
# LLM_MODEL_NAME=meta-llama/llama-3.3-70b-instruct:free
# LLM_MODEL_NAME=qwen/qwen3-next-80b-a3b-instruct
# LLM_MODEL_NAME=openai/gpt-oss-120b
# LLM_MODEL_NAME=anthropic/claude-3.5-sonnet
# LLM_MODEL_NAME=anthropic/claude-3-haiku
# LLM_MODEL_NAME=qwen/qwen3-coder
LLM_MODEL_NAME=z-ai/glm-4.7
# LLM_MODEL_NAME=z-ai/glm-5
# DESCRIPTION_MODEL=google/gemini-3.1-flash-lite-preview
DESCRIPTION_MODEL=openai/gpt-oss-120b

# Secondary model: used for lightweight tasks (spec summarization, etc.)
# Use a fast/cheap model to reduce main context token usage
SECONDARY_MODEL=qwen/qwen3-next-80b-a3b-instruct
# SECONDARY_MODEL=google/gemini-2.0-flash-lite
# SECONDARY_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ============================================================
# LLM Profiles  (multi-provider switching)
# ============================================================
# Each profile bundles BASE_URL + API_KEY + MODEL so /model <name>
# (or --model <name> at startup) flips the whole trio in one shot.
# Selection order: /model <name>  >  --model  >  LLM_PROFILE  >  legacy LLM_*
# Edit and save .env — running process picks up changes on the next
# /api/info or LLM call (mtime-watched, no restart needed).
#
# PROFILE_deepseek_BASE_URL=https://api.deepseek.com
# PROFILE_deepseek_API_KEY=sk-your-deepseek-key
# PROFILE_deepseek_MODEL=deepseek-v4-pro
#
# PROFILE_glm_BASE_URL=https://api.z.ai/api/coding/paas/v4
# PROFILE_glm_API_KEY=your-zai-key
# PROFILE_glm_MODEL=glm-5.1
#
# PROFILE_kimi_BASE_URL=https://inference.canopywave.io/v1
# PROFILE_kimi_API_KEY=your-kimi-key
# PROFILE_kimi_MODEL=kimi-2.6
#
# Pick the active one (only the *MODEL key is required per profile —
# BASE_URL/API_KEY fall back to LLM_BASE_URL/LLM_API_KEY when omitted).
# LLM_PROFILE=glm

# ============================================================
# ATLAS right-panel model dropdown
# ============================================================
# These are the model choices shown in the ATLAS right sidebar.
# Portable path: keep provider-specific URL/API key/model under PROFILE_*,
# then list raw models or profile refs here. This lets each machine use
# different provider URLs/model IDs without code changes.
#
# Raw model entries use the active provider/opencode routing:
#   gpt-5.5,gpt-5.4,gpt-5.3-codex
# Profile entries switch BASE_URL/API_KEY/MODEL atomically:
#   kimi=profile:kimi,deepseek=profile:deepseek,glm=profile:glm
#
# CLI backend entries route through local tools instead of HTTP providers:
#   cursor=cursor-cli,claude=claude-cli:sonnet
#
# Recommended:
# LLM_MODEL_CATALOG=gpt-5.5,gpt-5.4,gpt-5.3-codex,kimi=profile:kimi,deepseek=profile:deepseek,glm=profile:glm,cursor=cursor-cli,claude=claude-cli:sonnet
#
# Legacy slots are still supported for small local dropdowns.
# LLM_MODEL_NAME is the default/current slot; _2/_3 are optional.
LLM_MODEL_CATALOG=
LLM_MODEL_NAME_2=
LLM_MODEL_NAME_3=
# Current selected slot. ATLAS updates this when the user changes the dropdown.
LLM_SELECTED_MODEL_KEY=LLM_MODEL_NAME
# Runtime/pricing mirror for the selected slot. Usually matches the selected model.
LLM_ACTIVE_MODEL_NAME=z-ai/glm-4.7
LLM_ACTIVE_BASE_NAME=z-ai/glm-4.7

# ============================================================
# Sub-Agent Model Configuration
# ============================================================
# LOW: 빠르고 저렴한 모델 (explore, execute, review, task)
# HIGH: 고성능 추론 모델 (plan)
# PRIMARY: 메인 에이전트 모델
# SUBAGENT_LOW_MODEL=openrouter/qwen/qwen3-next-80b-a3b-instruct
# SUBAGENT_HIGH_MODEL=openrouter/z-ai/glm-4.7
SUBAGENT_LOW_MODEL=openai/gpt-oss-120b
SUBAGENT_HIGH_MODEL=openai/gpt-oss-120b

# ============================================================
# Embedding Configuration
# ============================================================
# Embedding API URL (OpenAI compatible)
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# Embedding API Key (fallback to LLM_API_KEY if not set)
EMBEDDING_API_KEY=your-openrouter-api-key-here

# Embedding model name
EMBEDDING_MODEL=qwen/qwen3-embedding-8b

# RAG storage directory (absolute path for project-local storage)
RAG_DIR=~/.rag
# RAG config file path (project .ragconfig for indexing patterns)
RAG_CONFIG_PATH=
RAG_RATE_LIMIT_DELAY_MS=1000

# ============================================================
# Token & Rate Limit Configuration
# ============================================================
# Maximum tokens the model can generate per response (hard cap: 64K)
# Recommended: >= 16384 for coding agents with large context.
# For reasoning models (GPT-5.x, GLM, DeepSeek), the effective budget
# is MAX_OUTPUT_TOKENS + MAX_REASONING_TOKENS.
MAX_OUTPUT_TOKENS=32000
# MAX_REASONING_TOKENS=8000
# Responses API reasoning control:
# none | low | medium | high | xhigh
REASONING_MODE=medium
# Backward-compatible alias used by older code paths.
REASONING_EFFORT=medium
# Request visible reasoning summary when supported by the provider
# RESPONSES_REASONING_SUMMARY=true

# TPM: Tokens Per Minute limit (0 = disabled)
# RPM: Requests Per Minute limit (0 = disabled)
# Example for GLM-4.6 free tier: TPM=50000 RPM=20
TPM_LIMIT=0
RPM_LIMIT=0

# ============================================================
# Compression Configuration
# ============================================================
TURN_PROTECTION_COUNT=0

# ============================================================
# ATLAS auth, email verification, recovery, and feedback mail
# ============================================================
# First-run fixed admin login. The admin row is created on the first successful
# login with this username/password, and existing DB users are not overwritten.
#ATLAS_DEFAULT_ADMIN_ENABLED=true
#ATLAS_DEFAULT_ADMIN_USERNAME=admin
#ATLAS_DEFAULT_ADMIN_PASSWORD=1151

# Signup email verification is opt-in so existing local/dev test accounts keep
# working until SMTP is configured. When enabled, registration requires:
#   1) username/password/email
#   2) POST /api/auth/email-code purpose=register
#   3) /api/auth/register with verification_code
#ATLAS_AUTH_EMAIL_VERIFICATION_ENABLED=false
#ATLAS_AUTH_EMAIL_CODE_TTL_SECONDS=600
#ATLAS_AUTH_EMAIL_CODE_MAX_ATTEMPTS=6
# Development only: include verification_code in API responses.
#ATLAS_AUTH_EMAIL_DEBUG=false

# Account recovery enables Find ID / Forgot PW flows. Those flows can use
# email verification codes, and the older password-reset token link remains
# supported for compatibility.
#ATLAS_ACCOUNT_RECOVERY_ENABLED=false
#ATLAS_ACCOUNT_RECOVERY_EMAIL_ENABLED=false
#ATLAS_ACCOUNT_RECOVERY_DEBUG=false

# SMTP settings used by signup/recovery codes and admin feedback email.
#ATLAS_SMTP_HOST=smtp.example.com
#ATLAS_SMTP_PORT=587
#ATLAS_SMTP_TLS=true
#ATLAS_SMTP_USERNAME=atlas@example.com
#ATLAS_SMTP_PASSWORD=your-smtp-password
#ATLAS_SMTP_FROM=atlas@example.com
# Admin sender/recipient address. Used as SMTP From fallback for signup codes,
# ID/PW recovery codes, and admin feedback notifications.
#ATLAS_ADMIN_EMAIL=admin@example.com

# Feedback submitted with /feedback is stored in DB and emailed to these
# admins when SMTP is configured. If omitted, DB users with role='admin' and
# an email address are used.
#ATLAS_FEEDBACK_EMAIL_ENABLED=true
#ATLAS_FEEDBACK_EMAIL_TO=admin@example.com

# ============================================================
# PDK / EDA library paths
# ============================================================
# Relative paths are resolved from common_ai_agent/, not the shell cwd.
# This lets syn/sta/dft/pnr scripts find the bundled PDK even when launched
# from an IP workspace directory.
PDK_ROOT=pdk
SKY130_PDK_ROOT=pdk/sky130
PDK_LIB_PATH=pdk/sky130/lib
SKY130_LIB=pdk/sky130/lib/sky130_fd_sc_hd__ss_100C_1v40.lib
SKY130_TLEF=pdk/sky130/lef/sky130_fd_sc_hd.tlef
SKY130_LEF=pdk/sky130/lef/sky130_fd_sc_hd_merged.lef
SKY130_TRACKS=pdk/sky130/make_tracks.tcl
SKY130_RCX_RULES=pdk/sky130/rcx_patterns.rules

# SSL settings → ~/.config/common_ai_agent/config 에서 설정 (not .env)
#   SSL_VERIFY=false

# ============================================================
# cursor-agent Backend (optional — replaces direct LLM API calls)
# ============================================================
# Set to true to route all LLM calls through the cursor-agent CLI
# instead of making HTTP requests to LLM_BASE_URL.
# Requires: cursor-agent installed at /usr/local/bin/cursor-agent or PATH.
# Default: false
#CURSOR_AGENT_ENABLE=true

# Model to pass via --model flag (free plan: only "auto" is available)
# Run `cursor-agent --list-models` to see available models.
# Default: auto
#CURSOR_AGENT_MODEL=auto

# Pass --yolo to allow write/shell tools without per-action confirmation
# Default: false
#CURSOR_AGENT_YOLO=false

# Execution mode: "ask" (read-only Q&A), "plan" (planning), or "" (full agent)
# Default: "" (full agent with tool access)
#CURSOR_AGENT_MODE=

# Workspace directory passed to cursor-agent (defaults to current directory)
#CURSOR_AGENT_WORKSPACE=

# Active Mode: primary LLM delegates most execution to cursor_agent tool
# LLM retains todo tracking and orchestration; cursor-agent handles the rest
#CURSOR_AGENT_ACTIVE_MODE=true

# Shortcut: `--model cursor-cli` or `/model cursor-cli` enables this backend.
# You can pin a Cursor model inline with `cursor-cli:<model>` or via:
#CURSOR_AGENT_MODEL=auto

# ============================================================
# Claude CLI Backend (optional — replaces direct LLM API calls)
# ============================================================
# Shortcut: `--model claude-cli` or `/model claude-cli`.
# Requires the `claude` CLI on PATH and a logged-in Claude Code session.
# Common AI Agent still owns tool execution; Claude's built-in tools are
# disabled by default via CLAUDE_CLI_TOOLS=. The default json output is the
# stable `claude -p --output-format json` path and preserves usage/cost data.
#CLAUDE_CLI_ENABLE=false
#CLAUDE_CLI_MODEL=sonnet
#CLAUDE_CLI_PERMISSION_MODE=default
#CLAUDE_CLI_TOOLS=
#CLAUDE_CLI_WORKSPACE=
#CLAUDE_CLI_NO_SESSION_PERSISTENCE=true
#CLAUDE_CLI_OUTPUT_FORMAT=json
#CLAUDE_CLI_TIMEOUT_SEC=300

# MCP server secrets — referenced as ${VAR} in .mcp.json env blocks
# MCP_Z_AI_API_KEY=your_z_ai_key_here
# BRAVE_API_KEY=your_brave_search_key_here

# ============================================================
# ATLAS UI ↔ workflow worker routing
# ============================================================
# atlas_ui.py looks up each workflow's worker URL via:
#   1. ATLAS_WORKER_URL_<SUFFIX>
#   2. ATLAS_<SUFFIX>_WORKER_URL
#   3. WORKER_URL_<SUFFIX>
#   4. canonical port-map default (src/atlas_api_jobs.py:_DEFAULT_WORKER_PORTS)
#   5. WORKER_URL_DEFAULT (final fallback: http://localhost:8001)
#
# The canonical port map ALREADY matches what `doc/wiki/atlas-browser-control-runbook.md`
# documents, so leaving these lines commented is the right default when the
# operator starts workers on the documented ports. Uncomment + edit to point at
# remote workers, alternate ports, or a load balancer.
#
# Suffix = workflow name uppercased with - and / replaced by _ (so
# `fl-model-gen` → `FL_MODEL_GEN`, `sim_debug` → `SIM_DEBUG`).
#WORKER_URL_SSOT_GEN=http://127.0.0.1:5621
#WORKER_URL_FL_MODEL_GEN=http://127.0.0.1:5622
#WORKER_URL_RTL_GEN=http://127.0.0.1:5623
#WORKER_URL_LINT=http://127.0.0.1:5624
#WORKER_URL_TB_GEN=http://127.0.0.1:5625
#WORKER_URL_SIM=http://127.0.0.1:5626
#WORKER_URL_COVERAGE=http://127.0.0.1:5627
#WORKER_URL_SIM_DEBUG=http://127.0.0.1:5628
#WORKER_URL_SYN=http://127.0.0.1:5629
#WORKER_URL_STA=http://127.0.0.1:5630
#WORKER_URL_PNR=http://127.0.0.1:5631
#WORKER_URL_STA_POST=http://127.0.0.1:5632
#WORKER_URL_DEFAULT=http://localhost:8001

# Per-workflow worker model overrides (canonical defaults live in
# src/atlas_api_jobs.py:_WORKER_MODEL_DEFAULTS). Resolution order:
#   1. ATLAS_WORKER_MODEL_<SUFFIX>
#   2. ATLAS_<SUFFIX>_MODEL
#   3. WORKER_MODEL_<SUFFIX>
#   4. _WORKER_MODEL_DEFAULTS[workflow]
# Examples below pin every worker to a GLM / DeepSeek / Kimi provider so a
# free-tier run stays off the more expensive gpt-5 family. Uncomment to apply.
#ATLAS_WORKER_MODEL_SSOT_GEN=glm-5.1
#ATLAS_WORKER_MODEL_FL_MODEL_GEN=glm-5.1
#ATLAS_WORKER_MODEL_RTL_GEN=deepseek-v4-pro
#ATLAS_WORKER_MODEL_LINT=deepseek-v4-pro
#ATLAS_WORKER_MODEL_TB_GEN=deepseek-v4-pro
#ATLAS_WORKER_MODEL_SIM=deepseek-v4-pro
#ATLAS_WORKER_MODEL_COVERAGE=deepseek-v4-pro
#ATLAS_WORKER_MODEL_SIM_DEBUG=kimi-k2-thinking
#ATLAS_WORKER_MODEL_SYN=deepseek-v4-pro
#ATLAS_WORKER_MODEL_STA=deepseek-v4-pro
#ATLAS_WORKER_MODEL_PNR=deepseek-v4-pro
#ATLAS_WORKER_MODEL_STA_POST=deepseek-v4-pro

# Orchestrator chat-loop model (atlas_ui.py / src/orchestrator/loop.py).
# Same provider preference; orchestrator does light reasoning over evidence
# JSON, so a thinking-class GLM or Kimi is enough.
#ATLAS_ORCHESTRATOR_MODEL=glm-5.1
#ATLAS_ORCHESTRATOR_REASONING=medium
