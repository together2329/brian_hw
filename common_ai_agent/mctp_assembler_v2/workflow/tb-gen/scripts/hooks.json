{
  "hooks": [
    {
      "script": "post_write.sh",
      "trigger": "after_tool",
      "conditions": {
        "tool_names": ["write_file", "replace_in_file"],
        "file_extensions": [".sv", ".v", ".py"]
      }
    },
    {
      "script": "sim_result_capture.sh",
      "trigger": "after_tool",
      "conditions": {
        "tool_names": ["run_command"],
        "output_contains": ["errors", "warnings", "PASS", "FAIL", "passed", "failed", "results.xml"]
      }
    },
    {
      "script": "disk_diff.sh",
      "trigger": "after_tool",
      "conditions": {
        "tool_names": ["write_file", "replace_in_file", "replace_lines", "run_command"],
        "every_n_iterations": 1
      }
    }
  ]
}
