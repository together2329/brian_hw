{
  "schema_version": 1,
  "type": "generic_ssot_rule_rtl_contract",
  "ip": "arbiter_rr",
  "top": "arbiter_rr",
  "contract": {
    "clock": "PCLK",
    "reset": "PRESETn",
    "reset_active": "low",
    "sample_condition": "PRESETn == 1",
    "input_map": {
      "requests": "req_i"
    },
    "csr_input_map": {
      "mask": "registers.REQ_MASK.mask",
      "enable": "registers.CTRL.enable"
    },
    "outputs": [
      {
        "name": "grant",
        "expr": "one_hot(selected_index)",
        "width": "NUM_REQ",
        "port": "gnt_o",
        "source": {
          "name": "grant",
          "expr": "one_hot(selected_index)",
          "width": "NUM_REQ",
          "port": "gnt_o",
          "description": "One-hot grant to selected requestor"
        }
      },
      {
        "name": "grant_valid",
        "expr": "enable && (masked_reqs != 0)",
        "width": 1,
        "port": "gnt_valid_o",
        "source": {
          "name": "grant_valid",
          "expr": "enable && (masked_reqs != 0)",
          "width": 1,
          "port": "gnt_valid_o"
        }
      },
      {
        "name": "grant_index",
        "expr": "selected_index",
        "width": "IDX_WIDTH",
        "port": "gnt_idx_o",
        "source": {
          "name": "grant_index",
          "expr": "selected_index",
          "width": "IDX_WIDTH",
          "port": "gnt_idx_o"
        }
      }
    ],
    "output_map": {
      "grant": "gnt_o",
      "grant_valid": "gnt_valid_o",
      "grant_index": "gnt_idx_o"
    },
    "state_updates": [
      {
        "name": "last_winner",
        "reset": 0,
        "expr": "grant_valid ? grant_index : last_winner"
      },
      {
        "name": "arb_enabled",
        "reset": 1,
        "expr": "CTRL.enable (from APB write)"
      },
      {
        "name": "req_mask",
        "reset": "all-ones",
        "expr": "REQ_MASK.mask (from APB write)"
      }
    ],
    "state_vars": {
      "last_winner": { "reset": 0, "width": "IDX_WIDTH" },
      "arb_enabled": { "reset": 1, "width": 1 },
      "req_mask": { "reset": "all-ones", "width": "NUM_REQ" }
    },
    "special_outputs": {},
    "transaction": "FM1",
    "source": "SSOT rtl_contract repaired for concrete top-level TB port binding"
  }
}
