      "interface/cycle assertion failure",
      "CL target vs measured performance gap",
      "minimal regression reproducer",
      "report/root-cause evidence gap"
    ],
    "loopable_oracles": [
      "traceability gap",
      "FL expected vs RTL actual diff",
